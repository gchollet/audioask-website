---
const { activePage = '' } = Astro.props;
const APP_URL = 'https://app.audioask.ai';
---

<header class="site-header">
  <div class="container site-header-inner">
    <a href="/" class="site-logo">
      <span class="logo-mark">A</span>
      <span>Audioask</span>
    </a>
    <nav class="site-nav">
      <span class="nav-dropdown">
        <a href="/fonctionnalites/transcrire" class="has-caret">Fonctionnalités</a>
        <div class="nav-submenu">
          <a href="/fonctionnalites/transcrire">
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/></svg></span>
            <span><span class="st">Transcrire</span><span class="sd">De l'audio au texte structuré en minutes</span></span>
          </a>
          <a href="/fonctionnalites/interroger">
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/></svg></span>
            <span><span class="st">Interroger</span><span class="sd">Posez vos questions, l'épisode répond</span></span>
          </a>
          <a href="/fonctionnalites/automatiser">
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg></span>
            <span><span class="st">Automatiser</span><span class="sd">Chaque nouvel épisode traité tout seul</span></span>
          </a>
          <a href="/fonctionnalites/traduire">
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h12M9 3v3M11 12L7 6 3 12M16 11h6"/></svg></span>
            <span><span class="st">Traduire <span class="soon">PROCHAINEMENT</span></span><span class="sd">12 langues + audio doublé</span></span>
          </a>
        </div>
      </span>
      <a href="/tarifs" class={activePage === 'tarifs' ? 'active' : ''}>Tarifs</a>
      <a href="#">Blog</a>
      <a href="/a-propos" class={activePage === 'a-propos' ? 'active' : ''}>À propos</a>
      <a href="/pro" class={activePage === 'pro' ? 'active' : ''}>Pour les pros</a>
    </nav>
    <div class="site-header-right">
      <div class="lang-switch" data-lang>
        <span>🇫🇷</span><span>FR</span><span style="opacity:.5;font-size:10px;">▾</span>
        <div class="lang-menu">
          <a href="#" class="on">🇫🇷 Français</a>
          <a href="#">🇬🇧 English</a>
          <a href="#">🇩🇪 Deutsch</a>
          <a href="#">🇮🇹 Italiano</a>
          <a href="#">🇪🇸 Español</a>
        </div>
      </div>
      <a class="btn btn-ghost sm" href={`${APP_URL}/login`}>Se connecter</a>
      <a class="btn btn-primary sm" href={`${APP_URL}/signup`}>Essayer gratuitement</a>
    </div>
  </div>
</header>

<script>
document.querySelectorAll('[data-lang]').forEach(d => {
  d.addEventListener('click', e => {
    e.stopPropagation();
    (d as HTMLElement).classList.toggle('open');
  });
});
document.addEventListener('click', () => {
  document.querySelectorAll('[data-lang].open').forEach(d => d.classList.remove('open'));
});
</script>

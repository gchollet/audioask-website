---
const { activePage = '', lang = 'fr', alternatePath } = Astro.props;
const APP_URL = 'https://dev-app.audioask.ai';

const isFr = lang === 'fr';

const nav = {
  features:  isFr ? 'Fonctionnalités'   : 'Features',
  pro:       isFr ? 'Pour les pros'      : 'For Professionals',
  pricing:   isFr ? 'Tarifs'             : 'Pricing',
  about:     isFr ? 'À propos'           : 'About',
  login:     isFr ? 'Se connecter'       : 'Sign in',
  signup:    isFr ? 'Essayer gratuitement' : 'Try for free',
};

const links = {
  transcribe: isFr ? '/fonctionnalites/transcrire'  : '/en/features/transcribe',
  ask:        isFr ? '/fonctionnalites/interroger'  : '/en/features/ask',
  automate:   isFr ? '/fonctionnalites/automatiser' : '/en/features/automate',
  translate:  isFr ? '/fonctionnalites/traduire'    : '/en/features/translate',
  mobile:     isFr ? '/app-mobile'                  : '/en/mobile',
  pro:        isFr ? '/pro'                          : '/en/professionals',
  pricing:    isFr ? '/tarifs'                       : '/en/pricing',
  about:      isFr ? '/a-propos'                    : '/en/about',
  home:       isFr ? '/'                             : '/en/',
};

const sub = isFr ? {
  transcribe: { label: 'Transcrire',   desc: 'De l\'audio au texte structuré en minutes' },
  ask:        { label: 'Interroger',   desc: 'Posez vos questions, l\'épisode répond' },
  automate:   { label: 'Automatiser',  desc: 'Chaque nouvel épisode traité tout seul' },
  translate:  { label: 'Traduire',     desc: '12 langues + audio doublé' },
  mobile:     { label: 'App mobile',   desc: 'iOS & Android — rejoindre la liste' },
} : {
  transcribe: { label: 'Transcribe',   desc: 'Audio to structured text in minutes' },
  ask:        { label: 'Ask AI',       desc: 'Ask questions, get answers from any episode' },
  automate:   { label: 'Automate',     desc: 'Every new episode processed automatically' },
  translate:  { label: 'Translate',    desc: '12 languages + dubbed audio' },
  mobile:     { label: 'Mobile app',   desc: 'iOS & Android — join the waitlist' },
};

const soon = isFr ? 'PROCHAINEMENT' : 'COMING SOON';

// Langue alternative pour le switcher
const altLang = isFr ? 'en' : 'fr';
const altHref = alternatePath ?? (isFr ? '/en/' : '/');
---

<header class="site-header">
  <div class="container site-header-inner">
    <a href={links.home} class="site-logo">
      <span class="logo-mark">A</span>
      <span>Audioask</span>
    </a>
    <nav class="site-nav">
      <span class="nav-dropdown">
        <a href={links.transcribe} class="has-caret">{nav.features}</a>
        <div class="nav-submenu">
          <a href={links.transcribe}>
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/></svg></span>
            <span><span class="st">{sub.transcribe.label}</span><span class="sd">{sub.transcribe.desc}</span></span>
          </a>
          <a href={links.ask}>
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/></svg></span>
            <span><span class="st">{sub.ask.label}</span><span class="sd">{sub.ask.desc}</span></span>
          </a>
          <a href={links.automate}>
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg></span>
            <span><span class="st">{sub.automate.label}</span><span class="sd">{sub.automate.desc}</span></span>
          </a>
          <a href={links.translate}>
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h12M9 3v3M11 12L7 6 3 12M16 11h6"/></svg></span>
            <span><span class="st">{sub.translate.label} <span class="soon">{soon}</span></span><span class="sd">{sub.translate.desc}</span></span>
          </a>
          <a href={links.mobile}>
            <span class="si"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg></span>
            <span><span class="st">{sub.mobile.label} <span class="soon">{soon}</span></span><span class="sd">{sub.mobile.desc}</span></span>
          </a>
        </div>
      </span>
      <a href={links.pro}  class={activePage === 'pro'    ? 'active' : ''}>{nav.pro}</a>
      <a href={links.pricing} class={activePage === 'tarifs' ? 'active' : ''}>{nav.pricing}</a>
      <a href={links.about}   class={activePage === 'a-propos' ? 'active' : ''}>{nav.about}</a>
    </nav>
    <div class="site-header-right">
      <div class="lang-switch" data-lang>
        <span>{isFr ? '🇫🇷' : '🇬🇧'}</span><span>{isFr ? 'FR' : 'EN'}</span><span style="opacity:.5;font-size:10px;">▾</span>
        <div class="lang-menu">
          {isFr ? (
            <>
              <a href="/" class="on">🇫🇷 Français</a>
              <a href={altHref}>🇬🇧 English</a>
              <a href="#">🇩🇪 Deutsch <span class="soon">PROCHAINEMENT</span></a>
              <a href="#">🇮🇹 Italiano <span class="soon">PROCHAINEMENT</span></a>
              <a href="#">🇪🇸 Español <span class="soon">PROCHAINEMENT</span></a>
            </>
          ) : (
            <>
              <a href={altHref}>🇫🇷 Français</a>
              <a href="/en/" class="on">🇬🇧 English</a>
              <a href="#">🇩🇪 Deutsch <span class="soon">COMING SOON</span></a>
              <a href="#">🇮🇹 Italiano <span class="soon">COMING SOON</span></a>
              <a href="#">🇪🇸 Español <span class="soon">COMING SOON</span></a>
            </>
          )}
        </div>
      </div>
      <a class="btn btn-ghost sm" href={`${APP_URL}/login`}>{nav.login}</a>
      <a class="btn btn-primary sm" href={`${APP_URL}/signup`}>{nav.signup}</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label={isFr ? 'Ouvrir le menu' : 'Open menu'} aria-expanded="false">
      <svg class="ico-menu" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="19" y2="6"/>
        <line x1="3" y1="11" x2="19" y2="11"/>
        <line x1="3" y1="16" x2="19" y2="16"/>
      </svg>
      <svg class="ico-close" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="4" x2="18" y2="18"/>
        <line x1="18" y1="4" x2="4" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-inner">
    <nav class="mobile-nav">
      <div class="mobile-section-label">{nav.features}</div>
      <a href={links.transcribe} class="mobile-nav-link">{sub.transcribe.label}</a>
      <a href={links.ask}        class="mobile-nav-link">{sub.ask.label}</a>
      <a href={links.automate}   class="mobile-nav-link">{sub.automate.label}</a>
      <a href={links.translate}  class="mobile-nav-link">{sub.translate.label}</a>
      <a href={links.mobile}     class="mobile-nav-link">{sub.mobile.label} <span class="soon" style="vertical-align: middle;">{soon}</span></a>
      <div class="mobile-divider"></div>
      <a href={links.pro}     class="mobile-nav-link">{nav.pro}</a>
      <a href={links.pricing} class="mobile-nav-link">{nav.pricing}</a>
      <a href={links.about}   class="mobile-nav-link">{nav.about}</a>
    </nav>
    <div class="mobile-cta">
      <a class="btn btn-ghost" href={`${APP_URL}/login`}  style="width:100%;justify-content:center;">{nav.login}</a>
      <a class="btn btn-primary" href={`${APP_URL}/signup`} style="width:100%;justify-content:center;">{nav.signup}</a>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('[data-lang]').forEach(d => {
  d.addEventListener('click', e => {
    e.stopPropagation();
    (d as HTMLElement).classList.toggle('open');
  });
});
document.addEventListener('click', () => {
  document.querySelectorAll('[data-lang].open').forEach(d => d.classList.remove('open'));
});

const hamburger = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobile-menu');
if (hamburger && mobileMenu) {
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.classList.toggle('open', !isOpen);
    document.body.classList.toggle('menu-open', !isOpen);
  });
}
</script>

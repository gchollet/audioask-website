---
interface Props { uid?: string; lang?: 'fr' | 'en'; }
const { uid = 'tease', lang = 'fr' } = Astro.props;
const isFr = lang === 'fr';
const phId   = `aa-${uid}-ph`;
const scrId  = `aa-${uid}-scr`;
const dotsId = `aa-${uid}-dots`;

const copy = isFr ? {
  eyebrow: 'Prochainement · iOS & Android',
  heading: 'Audioask dans<br><span class="serif-it">votre poche.</span>',
  lede: 'Toute votre bibliothèque, vos signets et vos automations dans une vraie app mobile. Même compte, même expérience — partout.',
  cta: "Découvrir l'app mobile",
  ctaHref: '/app-mobile',
} : {
  eyebrow: 'Coming soon · iOS & Android',
  heading: 'Audioask in<br><span class="serif-it">your pocket.</span>',
  lede: 'Your full library, bookmarks, and automations in a native mobile app. Same account, same experience — everywhere.',
  cta: 'Discover the mobile app',
  ctaHref: '/en/mobile',
};

const t = isFr ? {
  tabFeed: 'Feed', tabSearch: 'Recherche', tabPlay: 'Playlists', tabLib: 'Ma lib.',
  feedKick: 'Vos abonnements', feedTitle: 'Feed', chipAll: 'Tous',
  ep1: 'Construire la bonne chose, pas seulement bien la construire',
  ep2: 'Patagonia : bâtir une marque qui dit non à la croissance',
  ep3: 'La semaine de 4 jours, on a vraiment testé',
  ep4: 'Le goût comme compétence qui s\'entraîne',
  searchPlaceholder: '⌕ Podcasts, épisodes, sujets…',
  recentSearches: 'Recherches récentes',
  discover: 'Découvrir',
  follow: '+ Suivre',
  libTitle: 'Bibliothèque',
  chipCh: 'Channels', chipEp: 'Episodes', chipPr: 'Prompt',
  pod1: 'GDIY', pod1ep: '412 épisodes',
  pod2: 'Loycocracy', pod2ep: '38 épisodes',
  pod3: 'Acquired', pod3ep: '56 épisodes',
  pod4: 'Le Super Daily', pod4ep: '1009 épisodes',
  nowPlaying: 'EN LECTURE',
  artist: 'GDIY · Matthieu Stefani',
  tabTranscript: 'Transcript', tabBookmarks: 'Signets', tabAnswers: 'Réponses',
  transcribed: '● TRANSCRIT · suit la lecture',
  excerptIntro: "Bienvenue dans cet épisode. Aujourd'hui on s'attaque à une question qui revient sans cesse chez les fondateurs.",
  excerptQuote: 'La patience est un verbe : continuer, pas attendre.',
  askLabel: 'Ask',
  askCtx: 'Construire la bonne chose…',
  askQ: 'Quels sont les points clés et arguments principaux ?',
  askSumLabel: 'En une phrase',
  askSum: 'Un épisode sur la différence entre <b style="color:var(--ink);">vitesse</b> et <b style="color:var(--ink);">progrès</b>.',
  askKeyLabel: 'Points clés',
  askBullet1: '• Vitesse ≠ progrès — productif dans la mauvaise direction.',
  askBullet2: '• La patience est un verbe : continuer, pas attendre.',
  askCitations: '↩ 4 citations · 06:30 · 17:41 · 34:02',
  askInput: 'Posez une question…',
  miniTitle: 'Construire la bonne ch…',
  miniTime: '17:41 / 52:00',
  searchRecent1: '⟲ patagonia', searchRecent2: '⟲ instagram', searchRecent3: '⟲ patience',
  pod5: 'Culture IA', pod5sub: 'Anthony Morel · BFM',
  pod6: 'Culture Générale', pod6sub: 'Choses à savoir · 320 ép.',
  nowPlayingLabel: 'EN LECTURE',
  infoTab: 'Info',
  searchInTranscript: '⌕ Rechercher dans la transcription…',
} : {
  tabFeed: 'Feed', tabSearch: 'Search', tabPlay: 'Playlists', tabLib: 'Library',
  feedKick: 'Your subscriptions', feedTitle: 'Feed', chipAll: 'All',
  ep1: 'Build the right thing, not just build it right',
  ep2: 'Patagonia: building a brand that says no to growth',
  ep3: 'The 4-day work week: we actually tested it',
  ep4: 'Taste as a trainable skill',
  searchPlaceholder: '⌕ Podcasts, episodes, topics…',
  recentSearches: 'Recent searches',
  discover: 'Discover',
  follow: '+ Follow',
  libTitle: 'Library',
  chipCh: 'Channels', chipEp: 'Episodes', chipPr: 'Prompts',
  pod1: 'GDIY', pod1ep: '412 episodes',
  pod2: 'Loycocracy', pod2ep: '38 episodes',
  pod3: 'Acquired', pod3ep: '56 episodes',
  pod4: 'Le Super Daily', pod4ep: '1009 episodes',
  nowPlaying: 'NOW PLAYING',
  artist: 'GDIY · Matthieu Stefani',
  tabTranscript: 'Transcript', tabBookmarks: 'Bookmarks', tabAnswers: 'Answers',
  transcribed: '● TRANSCRIBED · follows playback',
  excerptIntro: 'Welcome to this episode. Today we tackle a question founders keep coming back to.',
  excerptQuote: 'Patience is a verb: keep going, not waiting.',
  askLabel: 'Ask',
  askCtx: 'Build the right thing…',
  askQ: 'What are the key takeaways and main arguments?',
  askSumLabel: 'In one sentence',
  askSum: 'An episode on the difference between <b style="color:var(--ink);">speed</b> and <b style="color:var(--ink);">progress</b>.',
  askKeyLabel: 'Key points',
  askBullet1: '• Speed ≠ progress — being productive in the wrong direction.',
  askBullet2: '• Patience is a verb: keep going, not waiting.',
  askCitations: '↩ 4 citations · 06:30 · 17:41 · 34:02',
  askInput: 'Ask a question…',
  miniTitle: 'Build the right thing…',
  miniTime: '17:41 / 52:00',
  searchRecent1: '⟲ patagonia', searchRecent2: '⟲ instagram', searchRecent3: '⟲ patience',
  pod5: 'AI Culture', pod5sub: 'Anthony Morel · BFM',
  pod6: 'General Knowledge', pod6sub: 'Choses à savoir · 320 ep.',
  nowPlayingLabel: 'NOW PLAYING',
  infoTab: 'Info',
  searchInTranscript: '⌕ Search in transcript…',
};
---

<!-- APP MOBILE TEASER -->
<section class="section">
  <div class="container">
    <div class="mobile-tease">
      <div class="mobile-tease-copy">
        <div class="eyebrow"><span class="dot">●</span> {copy.eyebrow}</div>
        <h2 style="margin-top: 16px;" set:html={copy.heading}></h2>
        <p class="lede" style="max-width: 38ch; margin-top: 20px;">{copy.lede}</p>
        <div style="margin-top: 32px;">
          <a class="btn btn-primary" href={copy.ctaHref}>{copy.cta} <span class="arrow">→</span></a>
        </div>
      </div>
      <div class="mobile-tease-visual">
        <div class="aa-tease-wrap">
          <div class="aa-phone" id={phId}>
            <div class="aa-island"></div>
            <div class="aa-screens" id={scrId}></div>
          </div>
          <div class="aa-dots" id={dotsId}></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ---- MOBILE TEASER LAYOUT ---- */
.mobile-tease {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.mobile-tease-visual { display: flex; justify-content: center; }

/* ---- PHONE ANIMATION (aa-*) ---- */
.aa-phone { width: 280px; height: 570px; border-radius: 46px; background: #0E0B0A; padding: 9px; box-shadow: 0 44px 100px -34px rgba(26,22,20,0.55), 0 14px 34px -12px rgba(26,22,20,0.25); transform: rotate(-3deg); flex-shrink: 0; }
.aa-screens { position: relative; width: 100%; height: 100%; border-radius: 38px; overflow: hidden; background: var(--cream); }
.aa-island { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 84px; height: 24px; background: #0E0B0A; border-radius: 13px; z-index: 9; }
.aa-screen { position: absolute; inset: 0; display: flex; flex-direction: column; opacity: 0; transform: translateY(14px) scale(0.99); transition: opacity .55s ease, transform .55s cubic-bezier(.22,1,.36,1); pointer-events: none; }
.aa-screen.on { opacity: 1; transform: none; }
.aa-screens:not([data-js]) .aa-screen:first-child { opacity: 1; transform: none; }
.aa-sb { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px 6px; font-size: 10px; font-weight: 600; color: var(--ink-2); flex-shrink: 0; }
.aa-pad { padding: 6px 14px 0; flex: 1; overflow: hidden; display: flex; flex-direction: column; }
.aa-kick { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 10px; }
.aa-h { font-size: 22px; font-weight: 700; letter-spacing: -0.03em; color: var(--ink); margin-bottom: 10px; }
.aa-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
.aa-chip { font-size: 10.5px; padding: 4px 10px; border-radius: 999px; background: var(--cream-2); color: var(--ink-2); border: 1px solid var(--line); }
.aa-chip.on { background: var(--accent-soft); color: var(--accent-ink); border-color: transparent; }
.aa-cover { border-radius: 8px; object-fit: cover; flex-shrink: 0; }
.aa-ep { display: flex; align-items: center; gap: 9px; padding: 7px 0; border-bottom: 1px solid var(--line); }
.aa-ep .t { font-size: 11.5px; font-weight: 600; line-height: 1.3; color: var(--ink); overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.aa-mini { display: flex; align-items: center; gap: 9px; margin: auto 12px 8px; padding: 8px 12px; background: var(--ink); border-radius: 14px; flex-shrink: 0; color: var(--cream); }
.aa-mini .pl { width: 26px; height: 26px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 10px; flex-shrink: 0; padding-left: 1px; }
.aa-tabs { display: flex; border-top: 1px solid var(--line); flex-shrink: 0; }
.aa-tab { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 7px 4px 4px; font-size: 8.5px; color: var(--ink-3); }
.aa-tab svg { width: 17px; height: 17px; }
.aa-tab.on { color: var(--accent); }
.aa-badge { display: inline-flex; align-items: center; font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 999px; white-space: nowrap; }
.aa-badge.accent { background: var(--accent); color: #fff; }
.aa-badge.soft { background: var(--cream-2); color: var(--ink-2); border: 1px solid var(--line); }
.aa-dots { display: flex; gap: 7px; margin-top: 20px; justify-content: center; }
.aa-dots i { width: 7px; height: 7px; border-radius: 50%; background: rgba(26,22,20,0.16); transition: width .35s, background .35s; display: block; }
.aa-dots i.on { width: 22px; border-radius: 4px; background: var(--accent); }
.aa-tease-wrap { display: flex; flex-direction: column; align-items: center; }
@media (prefers-reduced-motion: reduce) { .aa-screen { transition: none; } }

@media (max-width: 900px) {
  .mobile-tease { grid-template-columns: 1fr; gap: 40px; }
  .mobile-tease-visual { order: -1; }
  .aa-tease-wrap { transform: scale(0.7); transform-origin: top center; margin-bottom: -180px; }
}
</style>

<script define:vars={{ phId, scrId, dotsId, t }}>
(function () {
  var AA_CONFIG = { screenMs: 4200, pauseOffscreen: true };
  var ICON = {
    feed:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h16M4 12h16M4 18h10"/></svg>',
    search: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L22 22"/></svg>',
    play:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h11M4 12h11M4 18h7M19 7v10l4-2z"/></svg>',
    lib:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4v16M9 4l4 16M13 4v16M17 6l3 14"/></svg>',
  };
  function tabs(active) {
    var tabDefs = [['feed', t.tabFeed], ['search', t.tabSearch], ['play', t.tabPlay], ['lib', t.tabLib]];
    return '<div class="aa-tabs">' + tabDefs.map(function(a) {
      return '<span class="aa-tab' + (active===a[0]?' on':'') + '">' + ICON[a[0]] + a[1] + '</span>';
    }).join('') + '</div>';
  }
  var mini = '<div class="aa-mini"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:31px;height:31px;"><div><div style="font-size:11px;font-weight:600;color:var(--cream);">' + t.miniTitle + '</div><div style="font-size:9px;color:rgba(255,255,255,0.4);font-family:var(--mono);">' + t.miniTime + '</div></div><span class="pl">&#9658;</span></div>';
  var sb = '<div class="aa-sb"><span>9:41</span><span style="color:var(--ink);">●●● ⌃ ▭</span></div>';

  var SCREENS = [
    { screen: sb+'<div class="aa-pad"><div class="aa-kick">'+t.feedKick+'</div><div class="aa-h">'+t.feedTitle+'</div><div class="aa-chips"><span class="aa-chip on">'+t.chipAll+'</span><span class="aa-chip"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:15px;height:15px;border-radius:4px;">GDIY</span><span class="aa-chip">Loycocracy</span></div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:38px;height:38px;"><span class="t">'+t.ep1+'</span></div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-acquired.jpg" style="width:38px;height:38px;"><span class="t">'+t.ep2+'</span></div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-lex.jpg" style="width:38px;height:38px;"><span class="t">'+t.ep3+'</span></div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-huberman.jpg" style="width:38px;height:38px;"><span class="t">'+t.ep4+'</span></div></div>'+mini+tabs('feed') },
    { screen: sb+'<div class="aa-pad"><div class="aa-h">'+t.tabSearch+'</div><div style="background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:9px 12px;display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--ink-3);margin:11px 0 13px;">'+t.searchPlaceholder+'</div><div class="aa-kick" style="margin-bottom:7px;">'+t.recentSearches+'</div><div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:15px;"><span class="aa-chip">'+t.searchRecent1+'</span><span class="aa-chip">'+t.searchRecent2+'</span><span class="aa-chip">'+t.searchRecent3+'</span></div><div class="aa-kick" style="margin-bottom:7px;">'+t.discover+'</div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-a16z.jpg" style="width:38px;height:38px;"><div style="flex:1;"><div class="t">'+t.pod5+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod5sub+'</div></div><span class="aa-badge soft" style="font-size:10px;">'+t.follow+'</span></div><div class="aa-ep"><img class="aa-cover" src="/assets/pod-founders.jpg" style="width:38px;height:38px;"><div style="flex:1;"><div class="t">'+t.pod6+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod6sub+'</div></div><span class="aa-badge soft" style="font-size:10px;">'+t.follow+'</span></div></div>'+mini+tabs('search') },
    { screen: sb+'<div class="aa-pad"><div class="aa-h">'+t.libTitle+'</div><div class="aa-chips"><span class="aa-chip on">'+t.chipCh+'</span><span class="aa-chip">'+t.chipEp+'</span><span class="aa-chip">'+t.chipPr+'</span></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;"><div><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">'+t.pod1+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod1ep+'</div></div><div><img class="aa-cover" src="/assets/pod-huberman.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">'+t.pod2+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod2ep+'</div></div><div><img class="aa-cover" src="/assets/pod-acquired.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">'+t.pod3+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod3ep+'</div></div><div><img class="aa-cover" src="/assets/pod-lex.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">'+t.pod4+'</div><div style="font-size:9px;color:var(--ink-3);">'+t.pod4ep+'</div></div></div></div>'+mini+tabs('lib') },
    { screen: sb+'<div class="aa-pad" style="align-items:center;text-align:center;"><div style="display:flex;align-items:center;justify-content:space-between;width:100%;margin:2px 0 14px;"><span style="color:var(--ink-3);font-size:16px;">⌄</span><span style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;color:var(--ink-3);">'+t.nowPlayingLabel+'</span><span style="color:var(--accent);">♥</span></div><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:196px;height:196px;border-radius:18px;box-shadow:0 22px 46px -16px rgba(26,22,20,0.4);"><div style="font-size:15px;font-weight:700;letter-spacing:-0.02em;line-height:1.2;margin-top:16px;">'+t.ep1+'</div><div style="font-size:11px;color:var(--accent-ink);font-weight:600;margin-top:6px;">'+t.artist+'</div><div style="width:100%;margin-top:14px;"><div style="height:4px;background:var(--cream-3);border-radius:2px;position:relative;"><div style="position:absolute;left:0;top:0;bottom:0;width:34%;background:var(--accent);border-radius:2px;"></div><div style="position:absolute;left:34%;top:50%;transform:translate(-50%,-50%);width:11px;height:11px;border-radius:50%;background:var(--accent);"></div></div><div style="display:flex;justify-content:space-between;font-family:var(--mono);font-size:9px;color:var(--ink-3);margin-top:5px;"><span>17:41</span><span>−34:19</span></div></div><div style="display:flex;align-items:center;gap:18px;margin-top:14px;"><span style="color:var(--ink-2);font-size:13px;">↺15</span><span style="font-size:18px;">⏮</span><span style="width:54px;height:54px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px;">▶</span><span style="font-size:18px;">⏭</span><span style="color:var(--ink-2);font-size:13px;">30↻</span></div></div><div style="height:12px;"></div>' },
    { screen: sb+'<div class="aa-pad"><div style="display:flex;align-items:center;gap:9px;margin:4px 0 9px;"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:44px;height:44px;border-radius:10px;"><div><div style="font-size:12.5px;font-weight:600;line-height:1.2;">'+t.ep1+'</div><div style="font-size:9px;color:var(--ink-3);font-family:var(--mono);">28 MAY · 52 MIN</div></div></div><div style="display:flex;gap:7px;margin-bottom:9px;"><span style="font-size:11px;color:var(--ink-3);">'+t.infoTab+'</span><span style="font-size:11px;font-weight:600;border-bottom:2px solid var(--accent);padding-bottom:5px;">'+t.tabTranscript+'</span><span style="font-size:11px;color:var(--ink-3);">'+t.tabBookmarks+'</span><span style="font-size:11px;color:var(--ink-3);">'+t.tabAnswers+'</span></div><div style="background:var(--paper);border:1px solid var(--line);border-radius:10px;padding:8px 11px;display:flex;align-items:center;gap:7px;font-size:11px;color:var(--ink-3);margin-bottom:10px;">'+t.searchInTranscript+'</div><div style="display:flex;align-items:center;gap:6px;font-size:9px;color:var(--accent);font-family:var(--mono);margin-bottom:7px;">'+t.transcribed+'</div><div style="font-family:var(--mono);font-size:9px;color:var(--ink-3);margin-bottom:3px;">0:00 · SPEAKER_00</div><div style="font-size:11.5px;line-height:1.5;color:var(--ink-2);margin-bottom:9px;">'+t.excerptIntro+'</div><div style="font-family:var(--mono);font-size:9px;color:var(--accent-ink);margin-bottom:3px;">6:30 · SPEAKER_01</div><div style="font-size:11.5px;line-height:1.5;color:var(--ink);background:var(--accent-soft);padding:5px 8px;border-radius:6px;">'+t.excerptQuote+'</div></div>'+mini+tabs('feed') },
    { screen: sb+'<div class="aa-pad"><div style="display:flex;align-items:center;gap:9px;margin:4px 0 11px;"><span style="width:26px;height:26px;border-radius:8px;background:var(--accent-soft);color:var(--accent);display:flex;align-items:center;justify-content:center;">✦</span><div style="flex:1;"><b style="font-size:13px;">'+t.askLabel+'</b><div style="font-size:9px;color:var(--ink-3);">'+t.askCtx+'</div></div><span style="color:var(--ink-3);">✕</span></div><div style="align-self:flex-end;margin-left:auto;background:var(--cream-2);padding:9px 12px;border-radius:13px 13px 4px 13px;font-size:11.5px;max-width:80%;">'+t.askQ+'</div><div style="margin-top:9px;background:var(--paper);border:1px solid var(--line);border-radius:13px 13px 13px 4px;padding:11px 13px;font-size:11.5px;line-height:1.5;"><b>'+t.askSumLabel+'</b><div style="color:var(--ink-2);margin-top:3px;">'+t.askSum+'</div><b style="display:block;margin-top:8px;">'+t.askKeyLabel+'</b><div style="color:var(--ink-2);margin-top:4px;">'+t.askBullet1+'</div><div style="color:var(--ink-2);margin-top:3px;">'+t.askBullet2+'</div><div style="margin-top:8px;font-size:9px;font-family:var(--mono);color:var(--accent-ink);">'+t.askCitations+'</div></div></div><div style="padding:0 16px 8px;"><div style="background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:9px 12px;display:flex;align-items:center;gap:8px;font-size:11px;color:var(--ink-3);">'+t.askInput+'<span style="margin-left:auto;" class="aa-badge soft">'+t.askLabel+'</span></div></div>'+tabs('feed') },
  ];

  var scrEl  = document.getElementById(scrId);
  var dotsEl = document.getElementById(dotsId);
  var phoneEl = document.getElementById(phId);
  if (!scrEl || !dotsEl || !phoneEl) return;

  SCREENS.forEach(function (s) {
    var sc = document.createElement('div'); sc.className = 'aa-screen'; sc.innerHTML = s.screen; scrEl.appendChild(sc);
    var d  = document.createElement('i'); dotsEl.appendChild(d);
  });
  var screens = Array.from(scrEl.children), dots = Array.from(dotsEl.children);
  scrEl.setAttribute('data-js', '');
  var idx = 0, timer = null;
  function render() {
    screens.forEach(function (e, i) { e.classList.toggle('on', i === idx); });

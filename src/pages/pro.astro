function renderPersona(i) {
  const p = PERSONAS[i];
  document.getElementById('persona-pane').innerHTML = `
    <div>
      <div class="eyebrow"><span style="color: var(--accent);">0${i+1}</span> · Persona</div>
      <h3 style="font-size: 30px; margin-top: 14px; max-width: 22ch;">${p.title}</h3>
      <p style="color: var(--ink-2); margin-top: 16px; max-width: 50ch; font-size: 16px;">${p.body}</p>
      <div class="persona-quote">${p.quote}<div style="font-family: var(--sans); font-size: 12px; color: var(--ink-3); font-style: normal; margin-top: 8px; letter-spacing: 0;">— ${p.quoteFrom}</div></div>
    </div>
    <div style="background: var(--cream-2); border-radius: 18px; padding: 28px; aspect-ratio: 5/4; position: relative; border: 1px solid var(--line);">
      <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">${p.illuLabel}</div>
      <div style="margin-top: 14px; font-family: var(--serif); font-size: 38px; line-height: 1.05; letter-spacing: -0.03em; color: var(--accent-ink);">${p.illuStat}</div>
      <div style="position: absolute; bottom: 28px; left: 28px; right: 28px; padding: 14px; background: var(--paper); border: 1px solid var(--line); border-radius: 12px;">
        <div style="font-family: var(--mono); font-size: 9px; color: var(--ink-3); letter-spacing: 0.08em;">AUTOMATION ACTIVE</div>
        <div style="margin-top: 6px; font-size: 13px; color: var(--ink);">Chaque nouvel épisode → traité automatiquement.</div>
      </div>
    </div>
  `;
}
renderPersona(0);
document.querySelectorAll('.persona-tabs button').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.persona-tabs button').forEach(x => x.classList.remove('on'));
    b.classList.add('on');
    renderPersona(+b.dataset.tab);

---
import Layout from '../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---
<Layout title="Audioask Pro — Le plan pour les pros du podcast" description="Plan Pro Audioask : transcription à l'échelle, IA cross-épisodes, automations illimitées, prompts partagés. 19€/mois + usage." activePage="pro">

  <!-- HERO -->
  <section class="hero dotbg">
    <div class="container">
      <div class="hero-copy">
        <div class="hero-eyebrow">
          <span class="pill">PRO</span>
          <span>19€/mois + usage · 20h transcription &amp; 25M chars IA inclus</span>
        </div>
        <h1>
          Audioask sous <span class="em-serif">stéroïdes</span>&nbsp;:<br>
          le plan pro.
        </h1>
        <p class="lede">
          Pour les équipes qui veulent exploiter tout le savoir que les podcast ont à offrir. Transcription à l'échelle, IA cross-épisodes, automations sans limite.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary lg" href={`${APP_URL}/signup?plan=pro`}>Démarrer le plan Pro <span class="arrow">→</span></a>
          <a class="btn lg" href="/tarifs">Voir les tarifs</a>
        </div>
        <div class="hero-meta">
          <span class="dotcheck">Facturation transparente</span>
          <span class="dotcheck">Sans engagement</span>
        </div>
      </div>

      <!-- Animated feature tour -->
      <div class="product-stage" style="margin-top: 60px;">
        <div class="app-card pro-tour" id="pro-tour">
          <div class="app-toolbar">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            <span class="url">audioask.ai · plan pro</span>
          </div>
          <div class="pro-tour-body">
            <aside class="pro-tour-rail">
              <button class="pro-tour-tab on" data-scene="0">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h11l3 3v13H5z"/><path d="M9 9h6M9 13h6M9 17h3"/></svg></span>
                <span><b>Prompts illimités</b><small>enregistrés &amp; réutilisables</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="1">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/></svg></span>
                <span><b>IA cross-épisodes</b><small>tout un channel</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="2">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg></span>
                <span><b>Automations</b><small>illimitées</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="3">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 5h18v12H3z"/><path d="M8 21h8M9 9l3 2-3 2"/></svg></span>
                <span><b>Widget Embed</b><small>IA sur votre site</small></span>
                <span class="prog"></span>
              </button>
            </aside>

            <div class="pro-tour-stage">
              <!-- SCENE 0 · Prompts illimités -->
              <div class="pro-scene on" data-scene="0">
                <div class="pro-scene-head">
                  <span class="lbl">Mes prompts sauvegardés · 12</span>
                  <span class="chip accent-soft" style="font-size: 11px;">∞ ILLIMITÉ</span>
                </div>
                <div class="stagger s1 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px; border-color: var(--accent);">
                  <span style="color: var(--accent);">★</span>
                  <span style="flex: 1; font-size: 13px;">Brief client — angles &amp; insights</span>
                  <span class="chip accent-soft" style="height: 22px; font-size: 10.5px; padding: 0 8px;">▶ Lancer</span>
                </div>
                <div class="stagger s2 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">Résumé exécutif 5 points</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">42×</span>
                </div>
                <div class="stagger s3 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">Citations clés horodatées</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">31×</span>
                </div>
                <div class="stagger s4 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">Fact-check — sources &amp; chiffres</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">14×</span>
                </div>
                <div style="margin-top: 12px; font-size: 12px; color: var(--accent-ink); display: flex; align-items: center; gap: 8px;"><span>+</span> Nouveau prompt — aucune limite</div>
              </div>

              <!-- SCENE 1 · IA cross-épisodes -->
              <div class="pro-scene" data-scene="1">
                <div class="pro-scene-head">
                  <span class="lbl">Audioask · 142 épisodes interrogés</span>
                  <span class="chip" style="font-size: 11px;">CHANNEL · ACQUIRED</span>
                </div>
                <div class="ai-reveal r1 ai-bubble q" style="background: var(--cream-2); align-self: flex-end; max-width: 80%; margin-left: auto; padding: 11px 14px; border-radius: 14px 14px 4px 14px; font-size: 13px;">
                  Comment la thèse des hôtes sur l'IA a-t-elle évolué sur 3 saisons&nbsp;?
                </div>
                <div class="ai-reveal r2" style="margin-top: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px 14px 14px 4px; padding: 14px 16px; font-size: 13px; line-height: 1.55;">
                  <div>En <b>S1</b>, l'IA est vue comme un pari risqué. En <b>S2</b>, elle devient le fil conducteur. En <b>S3</b>, c'est la thèse centrale d'investissement.</div>
                  <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--line-2); font-size: 11px; color: var(--ink-3); display: flex; gap: 8px; flex-wrap: wrap;">
                    <span>↩ 6 citations ·</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#88 · 1:12:04</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#104 · 41:18</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#119 · 52:10</span>
                  </div>
                </div>
              </div>

              <!-- SCENE 2 · Automations -->
              <div class="pro-scene" data-scene="2">
                <div class="pro-scene-head">
                  <span class="lbl">Configurer l'automation · Acquired</span>
                  <span class="chip accent" style="font-size: 11px;">⚡ AUTO</span>
                </div>
                <div class="stagger s1 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">⚡</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Automatisation</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--accent); position: relative;"><span style="position: absolute; top: 2px; right: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
                <div class="stagger s2 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✦</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Prompt appliqué</span>
                  <span class="chip" style="height: 24px; font-size: 11px; padding: 0 10px; background: var(--cream-2); border-color: var(--line);">Brief client ▾</span>
                </div>
                <div class="stagger s3 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✉</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Envoi par email</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--accent); position: relative;"><span style="position: absolute; top: 2px; right: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
                <div class="stagger s4 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--cream-2); color: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">📚</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Enregistrer le résultat</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--cream-3); position: relative;"><span style="position: absolute; top: 2px; left: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
              </div>

              <!-- SCENE 3 · Widget Embed -->
              <div class="pro-scene" data-scene="3">
                <div class="pro-scene-head">
                  <span class="lbl">Widget embarqué · votre site</span>
                  <span class="chip accent-soft" style="font-size: 11px;">NOUVEAU</span>
                </div>
                <div class="embed-browser">
                  <div class="bar"><span class="d"></span><span class="d"></span><span class="d"></span><span class="addr">🔒 votresite.com/podcast</span></div>
                  <div class="embed-site" style="display: flex; flex-direction: column; gap: 10px;">
                    <div class="skel" style="width: 42%;"></div>
                    <div class="embed-widget">
                      <div style="display: flex; align-items: center; gap: 10px;">
                        <img src="/assets/acquired-cover.jpg" alt="" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;">
                        <div style="flex: 1; min-width: 0;"><div style="font-size: 12.5px; font-weight: 600;">#119 — Nvidia</div><div style="font-size: 11px; color: var(--ink-3);">Acquired</div></div>
                        <span style="width: 30px; height: 30px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 11px;">▶</span>
                      </div>
                      <div style="margin-top: 10px; height: 4px; background: var(--cream-2); border-radius: 2px; position: relative;"><div style="position: absolute; left: 0; top: 0; bottom: 0; width: 34%; background: var(--accent); border-radius: 2px;"></div></div>
                      <div style="margin-top: 10px; background: var(--cream); border: 1px solid var(--line); border-radius: 8px; padding: 7px 11px; font-size: 11.5px; color: var(--ink-3); display: flex; align-items: center; gap: 8px;">
                        <span style="color: var(--accent);">✦</span> Posez une question sur cet épisode…
                        <span style="margin-left: auto; font-family: var(--mono); font-size: 9px; background: var(--accent-tint); color: var(--accent-ink); padding: 2px 6px; border-radius: 4px;">IA</span>
                      </div>
                    </div>
                    <div class="skel" style="width: 88%;"></div>
                    <div class="skel" style="width: 64%;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES — alternating blocks -->
  <section class="section paper">
    <div class="container">
      <div class="row between" style="align-items: flex-end; flex-wrap: wrap; gap: 32px;">
        <div>
          <div class="eyebrow"><span class="dot">●</span> L'arsenal complet</div>
          <h2 style="margin-top: 16px;">Tout ce qu'il faut
pour donner de la valeur à vos podcasts.</h2>
        </div>
        <p class="lede" style="max-width: 38ch;">Des fonctionnalités pensées pour valoriser les contenus du vos podcasts ou ceux des autres.</p>
      </div>

      <!-- Feature 1 : IA cross-épisodes -->
      <div class="feature-alt" style="margin-top: 48px;">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">01</span> · IA cross-épisodes</div>
          <h3 style="margin-top: 12px;">Interrogez tout un channel, pas juste un épisode.</h3>
          <p>Posez une question à l'intégralité d'un podcast — toutes saisons confondues. Tendances, comparaison d'invités, évolution dans le temps. Chaque réponse est citée et horodatée.</p>
          <div style="margin-top: 24px; display: flex; align-items: baseline; gap: 12px;">
            <span style="font-family: var(--serif); font-size: 44px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">25M</span>
            <span style="font-size: 14px; color: var(--ink-3);">caractères d'IA inclus / mois</span>
          </div>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">142 ÉPISODES INTERROGÉS · ACQUIRED</div>
          <div style="background: var(--cream-2); border-radius: 14px 14px 4px 14px; padding: 11px 14px; font-size: 13px; max-width: 82%; margin-left: auto;">
            Comment la thèse des hôtes sur l'IA a-t-elle évolué sur 3 saisons&nbsp;?
          </div>
          <div style="margin-top: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px 14px 14px 4px; padding: 14px 16px; font-size: 13px; line-height: 1.55;">
            <div>En <b>S1</b>, l'IA est vue comme un pari risqué. En <b>S2</b>, elle devient le fil conducteur. En <b>S3</b>, c'est la thèse centrale d'investissement.</div>
            <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--line-2); font-size: 11px; color: var(--ink-3); display: flex; gap: 8px; flex-wrap: wrap;">
              <span>↩ 6 citations ·</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#88 · 1:12:04</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#104 · 41:18</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#119 · 52:10</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 2 : Prompts illimités -->
      <div class="feature-alt reverse">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">02</span> · Prompts illimités</div>
          <h3 style="margin-top: 12px;">Vos prompts, enregistrés et réutilisables à l'infini.</h3>
          <p>Créez, nommez et sauvegardez autant de prompts que vous voulez&nbsp;: brief client, synthèse exécutive, extraction de citations… Lancez-les en un clic sur n'importe quel épisode ou channel.</p>
          <div style="margin-top: 24px; display: flex; align-items: baseline; gap: 12px;">
            <span style="font-family: var(--serif); font-size: 44px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">∞</span>
            <span style="font-size: 14px; color: var(--ink-3);">prompts personnalisés &amp; partagés</span>
          </div>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto; display: flex; flex-direction: column; gap: 8px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 4px;">MES PROMPTS SAUVEGARDÉS · 12</div>
          <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--accent);">★</span>
            <span style="flex: 1;">Brief client — angles &amp; insights actionnables</span>
            <span class="chip accent-soft" style="height: 22px; font-size: 10.5px; padding: 0 8px;">▶ Lancer</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Résumé exécutif 5 points</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">utilisé 42×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Citations clés horodatées</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">utilisé 31×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Liste de livres &amp; outils mentionnés</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">utilisé 19×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Fact-check — sources &amp; chiffres</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">utilisé 14×</span>
          </div>
          <div style="margin-top: 2px; font-size: 11.5px; color: var(--accent-ink); display: flex; align-items: center; gap: 8px;"><span>+</span> Nouveau prompt — aucune limite</div>
        </div>
      </div>

      <!-- Feature 3 : Automations -->
      <div class="feature-alt">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">03</span> · Automations</div>
          <h3 style="margin-top: 12px;">Automations illimitées, livrées où vous voulez.</h3>
          <p>Chaque nouvel épisode déclenche votre workflow&nbsp;: transcription, prompt personnalisé, puis livraison automatique (email, Slack, webhook). Vous configurez une fois, ça tourne toute l'année.</p>
          <a href="/fonctionnalites/automatiser" class="btn btn-primary" style="margin-top: 20px; display: inline-flex;">En savoir plus <span class="arrow" style="margin-left: 6px;">→</span></a>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">CONFIGURER L'AUTOMATION · ACQUIRED</div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">⚡</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Automatisation</div><div style="font-size: 11px; color: var(--ink-3);">Traiter chaque nouvel épisode</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--accent); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✦</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Prompt appliqué</div><div style="font-size: 11px; color: var(--ink-3);">Choisissez parmi vos prompts</div></div>
              <span class="chip" style="height: 26px; font-size: 11.5px; padding: 0 11px; background: var(--cream-2); border-color: var(--line);">Brief client ▾</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✉</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Envoi par email</div><div style="font-size: 11px; color: var(--ink-3);">Dès que le résultat est prêt</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--accent); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--cream-2); color: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">📚</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Enregistrer le résultat</div><div style="font-size: 11px; color: var(--ink-3);">Dans votre bibliothèque</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--cream-3); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; left: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
          </div>

<script>
// --- Animated Pro feature tour (auto-cycling + clickable)
(function () {
  const tour = document.getElementById('pro-tour');
  if (!tour) return;
  const tabs = [...tour.querySelectorAll('.pro-tour-tab')];
  const scenes = [...tour.querySelectorAll('.pro-scene')];
  const DUR = 4600;
  let idx = 0, timer = null;
  tour.style.setProperty('--tour-dur', DUR + 'ms');

  function show(n, restart) {
    idx = n;
    tabs.forEach((t, i) => t.classList.toggle('on', i === n));
    // re-trigger the rail progress animation by reflow
    const onTab = tabs[n];
    if (onTab) { const p = onTab.querySelector('.prog'); if (p) { p.style.display = 'none'; void p.offsetWidth; p.style.display = ''; } }
    scenes.forEach((s, i) => s.classList.toggle('on', i === n));
    if (restart !== false) schedule();
  }
  function schedule() {
    clearTimeout(timer);
    timer = setTimeout(() => show((idx + 1) % scenes.length), DUR);
  }
  tabs.forEach((t, i) => t.addEventListener('click', () => show(i)));
  show(0);
})();

const PERSONAS = [
  {
    title: 'Gardez l\'historique complet de vos épisodes — et exploitez-le.',
    body: 'Toute votre back-catalog devient une bibliothèque indexable : cherchez une citation à travers 200 épisodes, ressortez un sujet de saison 2 en 10 secondes, alimentez vos newsletters à partir de votre propre archive. Plus rien ne se perd.',
    quote: '« On a indexé 380 épisodes en 2 semaines. Notre back-catalog n\'est plus un cimetière, c\'est un actif. »',
    quoteFrom: 'Éditeur · podcast quotidien',
    illuLabel: 'CATALOGUE INDEXÉ',
    illuStat: '380 épisodes · 142h audio',
  },
  {
    title: 'Faites la veille de vos clients — sans écouter 40 heures par semaine.',
    body: 'Chaque fois qu\'un de vos clients (ou leurs concurrents) est cité dans un podcast, vous le savez. Suivi de marques, citations horodatées, veille concurrentielle automatisée. Vos consultants livrent en heures ce qu\'ils faisaient en jours.',
    quote: '« Mes consultants reprennent leur métier : penser. Plus à ré-écouter pour traquer une citation. »',
    quoteFrom: 'Directrice · agence de comm',
    illuLabel: 'CITATIONS DE CLIENTS · 7 J',
    illuStat: '42 mentions · 14 podcasts',
  },
  {
    title: 'Citez précisément. Vérifiez en 10 secondes.',
    body: 'Fact-checking, citations horodatées, sources manipulables. Chaque phrase de votre article peut être tracée à la seconde près de l\'interview.',

---
import Layout from '../../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---

<Layout
  title="Audioask mobile app — iOS & Android — Coming soon"
  description="The Audioask app is coming to iPhone and Android. Listen, transcribe and ask AI about your podcasts on the go. Join the waitlist and be notified at launch."
  activePage=""
  lang="en"
  alternatePath="/app-mobile"
>

<!-- HERO -->
<section class="hero dotbg">
  <div class="container">
    <div class="mobile-hero-grid">

      <!-- Copy + form -->
      <div class="mobile-hero-copy">
        <div class="hero-eyebrow">
          <span class="pill">Coming soon</span>
          <span>iOS &amp; Android</span>
        </div>
        <h1>Audioask in<br><span class="em-serif">your pocket.</span></h1>
        <p class="lede">Your full library, bookmarks and automations in a real mobile app. Same account, same experience — wherever you are.</p>
        <div class="notify-block" id="notify-block">
          <p class="notify-label">Get notified when the app launches</p>
          <form class="notify-form" id="notify-form" novalidate>
            <input type="text" name="website" style="display:none;" autocomplete="off" tabindex="-1">
            <input type="email" id="notify-email" name="email" placeholder="your@email.com" required autocomplete="email"/>
            <button type="submit" class="btn btn-primary">Notify me <span class="arrow">→</span></button>
          </form>
          <p class="notify-meta">No spam. Just one email on launch day.</p>
          <div class="notify-success" id="notify-success" style="display: none;">
            <span class="notify-success-icon">✓</span>
            Got it! You'll be notified as soon as the app is available.
          </div>
          <div class="notify-error" id="notify-error" style="display: none;"></div>
        </div>
      </div>

      <!-- Animated phone (hidden on mobile) -->
      <div class="mobile-hero-visual" aria-hidden="true">
        <div class="aa-phone" id="aaHero">
          <div class="aa-island"></div>
          <div class="aa-screens" id="aaScreens"></div>
        </div>
        <div class="aa-dots" id="aaDots"></div>
      </div>

    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="section paper">
  <div class="container">
    <div class="center-text" style="max-width: 640px; margin: 0 auto; text-align: center;">
      <div class="eyebrow"><span class="dot">●</span> Same experience, everywhere</div>
      <h2 style="margin-top: 16px;">Everything you love about Audioask,<br><span class="serif-it">in your pocket.</span></h2>
    </div>

    <div class="mob-feat-grid">
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h12M4 12h12M4 18h7"/><path d="M18 13l5 3-5 3z"/></svg>
        </div>
        <div>
          <h3>Feed &amp; playlists</h3>
          <p>Your personalised feed, favourite channels and themed playlists — available offline.</p>
        </div>
      </div>
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div>
          <h3>Bookmarks &amp; favourites</h3>
          <p>Mark key moments with one tap. Find them again from any device.</p>
        </div>
      </div>
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/></svg>
        </div>
        <div>
          <h3>Transcriptions</h3>
          <p>Read episode transcripts. Navigate the text and jump to the right moment with a tap.</p>
        </div>
      </div>
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/></svg>
        </div>
        <div>
          <h3>AI Q&amp;A</h3>
          <p>Ask questions about any episode with your saved prompts. Review your favourite answers anywhere.</p>
        </div>
      </div>
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg>
        </div>
        <div>
          <h3>Automation notifications</h3>
          <p>Get alerted as soon as a new episode from your automated channels has been processed and delivered.</p>
        </div>
      </div>
      <div class="mob-feat">
        <div class="mob-feat-ico">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M16 16l5 5"/></svg>
        </div>
        <div>
          <h3>Global search</h3>
          <p>Find a passage, a name, or an idea across all your transcribed episodes — from your phone.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SAME ACCOUNT — DARK -->
<section class="section dark">
  <div class="container">
    <div style="max-width: 680px; margin: 0 auto; text-align: center;">
      <div class="eyebrow" style="color: var(--accent); justify-content: center;"><span class="dot">●</span> One account</div>
      <h2 style="margin-top: 20px;">Start on web,<br>continue on mobile.</h2>
      <p class="lede" style="margin-top: 20px; color: var(--night-text-2);">Your library, bookmarks, playlists and automations are synced instantly across all your devices. Start an episode on the web, finish it on the go.</p>
      <div style="margin-top: 36px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a class="btn btn-primary" href={`${APP_URL}/signup`}>Create a free account <span class="arrow">→</span></a>
        <a class="btn btn-ghost" href="/en/" style="color: var(--night-text); border-color: var(--night-line-2);">Discover Audioask</a>
      </div>
    </div>
  </div>
</section>

<!-- BOTTOM NOTIFY FORM -->
<section class="section">
  <div class="container">
    <div class="notify-bottom">
      <div>
        <h2>Don't miss the launch.</h2>
        <p class="lede" style="margin-top: 12px; max-width: 44ch;">Leave your email and be among the first to get the app when it lands on the App Store and Google Play.</p>
      </div>
      <div class="notify-block notify-block-inline" id="notify-block-2">
        <form class="notify-form" id="notify-form-2" novalidate>
          <input type="text" name="website" style="display:none;" autocomplete="off" tabindex="-1">
          <input
            type="email"
            id="notify-email-2"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn btn-primary">Notify me <span class="arrow">→</span></button>
        </form>
        <p class="notify-meta">No spam. Just one email on launch day.</p>
        <div class="notify-success" id="notify-success-2" style="display: none;">
          <span class="notify-success-icon">✓</span>
          Got it! You'll be notified as soon as the app is available.
        </div>
        <div class="notify-error" id="notify-error-2" style="display: none;"></div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style is:global>
.aa-phone { width: 280px; height: 570px; border-radius: 46px; background: #0E0B0A; padding: 9px; box-shadow: 0 44px 100px -34px rgba(26,22,20,0.55), 0 14px 34px -12px rgba(26,22,20,0.25); transform: rotate(-3deg); flex-shrink: 0; }
.aa-screens { position: relative; width: 100%; height: 100%; border-radius: 38px; overflow: hidden; background: var(--cream); }
.aa-island { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 84px; height: 24px; background: #0E0B0A; border-radius: 13px; z-index: 9; }
.aa-screen { position: absolute; inset: 0; display: flex; flex-direction: column; opacity: 0; transform: translateY(14px) scale(0.99); transition: opacity .55s ease, transform .55s cubic-bezier(.22,1,.36,1); pointer-events: none; }
.aa-screen.on { opacity: 1; transform: none; }
.aa-screens:not([data-js]) .aa-screen:first-child { opacity: 1; transform: none; }
.aa-sb { display: flex; align-items: center; justify-content: space-between; padding: 15px 22px 6px; font-size: 12px; font-weight: 600; color: var(--ink); }
.aa-pad { padding: 6px 16px 0; flex: 1; overflow: hidden; display: flex; flex-direction: column; }
.aa-kick { font-family: var(--mono); font-size: 8.5px; letter-spacing: 0.14em; color: var(--ink-3); text-transform: uppercase; }
.aa-h { font-size: 26px; font-weight: 700; letter-spacing: -0.03em; margin: 2px 0; }
.aa-chips { display: flex; gap: 6px; margin: 11px 0 9px; }
.aa-chip { height: 27px; padding: 0 11px; border-radius: 999px; display: flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 500; background: var(--paper); border: 1px solid var(--line); white-space: nowrap; }
.aa-chip.on { background: var(--ink); color: var(--cream); border-color: var(--ink); }
.aa-cover { border-radius: 8px; object-fit: cover; flex-shrink: 0; display: block; }
.aa-ep { display: flex; gap: 10px; align-items: center; padding: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px; margin-bottom: 7px; }
.aa-ep .t { font-size: 12px; font-weight: 600; line-height: 1.25; letter-spacing: -0.01em; }
.aa-mini { margin: 0 9px; border-radius: 15px; background: var(--ink); color: var(--cream); display: flex; align-items: center; gap: 9px; padding: 8px 10px; }
.aa-mini .pl { margin-left: auto; width: 32px; height: 32px; border-radius: 50%; background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
.aa-tabs { display: flex; justify-content: space-around; padding: 10px 8px 15px; }
.aa-tab { display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 8.5px; color: var(--ink-3); font-weight: 500; }
.aa-tab.on { color: var(--accent); }
.aa-tab svg { width: 17px; height: 17px; }
.aa-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.aa-badge.accent { background: var(--accent); color: #fff; }
.aa-badge.soft { background: var(--accent-soft); color: var(--accent-ink); }
.aa-dots { display: flex; gap: 7px; margin-top: 20px; justify-content: center; }
.aa-dots i { width: 7px; height: 7px; border-radius: 50%; background: rgba(26,22,20,0.16); transition: width .35s, background .35s; display: block; }
.aa-dots i.on { width: 22px; border-radius: 4px; background: var(--accent); }
@media (prefers-reduced-motion: reduce) { .aa-screen { transition: none; } }
</style>

<style>
/* ---- HERO ---- */
.mobile-hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: center;
  padding: 48px 0 80px;
}
.mobile-hero-copy h1 { font-size: clamp(36px, 5vw, 56px); }
.mobile-hero-copy .lede { margin: 20px 0 0; font-size: 18px; max-width: 44ch; }
.mobile-hero-visual { display: flex; flex-direction: column; align-items: center; }

/* ---- NOTIFY FORM ---- */
.notify-block { margin-top: 32px; }
.notify-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-2);
  margin-bottom: 10px;
  font-family: var(--mono);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.notify-form {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.notify-form input[type="email"] {
  flex: 1;
  min-width: 200px;
  height: 46px;
  border-radius: 10px;
  border: 1.5px solid var(--line);
  background: var(--paper);
  padding: 0 16px;
  font-size: 14px;
  color: var(--ink);
  font-family: inherit;
  outline: none;
  transition: border-color 0.15s;
}
.notify-form input[type="email"]:focus { border-color: var(--accent); }
.notify-form input[type="email"]::placeholder { color: var(--ink-3); }
.notify-meta {
  margin-top: 10px;
  font-size: 12px;
  color: var(--ink-3);
}
.notify-success {
  margin-top: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: var(--accent-soft);
  border: 1px solid var(--accent);
  border-radius: 10px;
  font-size: 14px;
  color: var(--ink);
}
.notify-success-icon { color: var(--accent); font-size: 16px; font-weight: 700; flex-shrink: 0; }
.notify-error {
  margin-top: 10px;
  font-size: 13px;
  color: #c0392b;
  padding: 10px 14px;
  background: rgba(192,57,43,0.08);
  border-radius: 8px;
  border: 1px solid rgba(192,57,43,0.2);
}

/* ---- FEATURES GRID ---- */
.mob-feat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px 40px;
  margin-top: 56px;
}
.mob-feat { display: flex; gap: 18px; align-items: flex-start; }
.mob-feat-ico {
  width: 44px; height: 44px; flex-shrink: 0;
  border-radius: 12px;
  background: var(--accent-tint);
  color: var(--accent-ink);
  display: flex; align-items: center; justify-content: center;
}
.mob-feat h3 { font-size: 16px; margin-bottom: 6px; }
.mob-feat p { font-size: 14px; color: var(--ink-2); line-height: 1.55; }

/* ---- NOTIFY BOTTOM ---- */
.notify-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.notify-block-inline { margin-top: 0; }

/* ---- RESPONSIVE ---- */
@media (max-width: 900px) {
  .mobile-hero-grid { grid-template-columns: 1fr; gap: 0; padding: 40px 0 48px; }
  .mobile-hero-visual { display: none; }
  .mob-feat-grid { grid-template-columns: 1fr 1fr; gap: 24px 32px; }
  .notify-bottom { grid-template-columns: 1fr; gap: 32px; }
}
@media (max-width: 600px) {
  .mob-feat-grid { grid-template-columns: 1fr; }
  .notify-form { flex-direction: column; }
  .notify-form input[type="email"] { min-width: auto; }
  .notify-form .btn { justify-content: center; }
}
</style>

<script>
(function () {
  const AA_CONFIG = { screenMs: 4200, pauseOffscreen: true };

  const ICON = {
    feed: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h10M4 12h10M4 18h6"/><circle cx="19" cy="7" r="1.5"/></svg>`,
    search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M16 16l4 4"/></svg>`,
    play: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h11M4 12h11M4 18h7M19 7v10l4-2z"/></svg>`,
    lib: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4v16M9 4l4 16M13 4v16M17 6l3 14"/></svg>`,
  };
  function tabs(active) {
    const t = [['feed','Feed'],['search','Search'],['play','Playlists'],['lib','My lib.']];
    return `<div class="aa-tabs">` + t.map(([k,l]) => `<span class="aa-tab${active===k?' on':''}">${ICON[k]}${l}</span>`).join('') + `</div>`;
  }
  const mini = `<div class="aa-mini"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:31px;height:31px;"><div><div style="font-size:11px;font-weight:600;">Build the right thing…</div><div style="font-size:9px;color:var(--ink-4);font-family:var(--mono);">17:41 / 52:00</div></div><span class="pl">▶</span></div>`;
  const sb = `<div class="aa-sb"><span>9:41</span><span style="color:var(--ink);">●●● ⌃ ▭</span></div>`;

  const SCREENS = [
    /* 1 · FEED */
    { screen: `${sb}<div class="aa-pad">
        <div class="aa-kick">Your subscriptions</div><div class="aa-h">Feed</div>
        <div class="aa-chips"><span class="aa-chip on">All</span><span class="aa-chip"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:15px;height:15px;border-radius:4px;">TKP</span><span class="aa-chip">Acquired</span></div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:38px;height:38px;"><span class="t">Build the right thing, not just build the thing right</span></div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-acquired.jpg" style="width:38px;height:38px;"><span class="t">Patagonia: building a brand that says no to growth</span></div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-lex.jpg" style="width:38px;height:38px;"><span class="t">The 4-day week: we actually tried it</span></div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-huberman.jpg" style="width:38px;height:38px;"><span class="t">Taste as a trainable skill</span></div>
      </div>${mini}${tabs('feed')}`},

    /* 2 · SEARCH */
    { screen: `${sb}<div class="aa-pad">
        <div class="aa-h">Search</div>
        <div style="background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:9px 12px;display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--ink-3);margin:11px 0 13px;">⌕ Podcasts, episodes, topics…</div>
        <div class="aa-kick" style="margin-bottom:7px;">Recent searches</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:15px;"><span class="aa-chip">⟲ patagonia</span><span class="aa-chip">⟲ nvidia</span><span class="aa-chip">⟲ patience</span></div>
        <div class="aa-kick" style="margin-bottom:7px;">Discover</div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-a16z.jpg" style="width:38px;height:38px;"><div style="flex:1;"><div class="t">a16z Podcast</div><div style="font-size:9px;color:var(--ink-3);">Andreessen Horowitz</div></div><span class="aa-badge soft" style="font-size:10px;">+ Follow</span></div>
        <div class="aa-ep"><img class="aa-cover" src="/assets/pod-founders.jpg" style="width:38px;height:38px;"><div style="flex:1;"><div class="t">Founders</div><div style="font-size:9px;color:var(--ink-3);">David Senra · 300+ eps.</div></div><span class="aa-badge soft" style="font-size:10px;">+ Follow</span></div>
      </div>${mini}${tabs('search')}`},

    /* 3 · LIBRARY */
    { screen: `${sb}<div class="aa-pad">
        <div class="aa-h">Library</div>
        <div class="aa-chips"><span class="aa-chip on">Channels</span><span class="aa-chip">Episodes</span><span class="aa-chip">Prompts</span></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;">
          <div><img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">The Knowledge Project</div><div style="font-size:9px;color:var(--ink-3);">412 episodes</div></div>
          <div><img class="aa-cover" src="/assets/pod-huberman.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">Huberman Lab</div><div style="font-size:9px;color:var(--ink-3);">38 episodes</div></div>
          <div><img class="aa-cover" src="/assets/pod-acquired.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">Acquired</div><div style="font-size:9px;color:var(--ink-3);">56 episodes</div></div>
          <div><img class="aa-cover" src="/assets/pod-lex.jpg" style="width:100%;aspect-ratio:1;border-radius:12px;"><div style="font-size:12px;font-weight:600;margin-top:5px;">Lex Fridman</div><div style="font-size:9px;color:var(--ink-3);">400+ episodes</div></div>
        </div>
      </div>${mini}${tabs('lib')}`},

    /* 4 · PLAYER */
    { screen: `${sb}<div class="aa-pad" style="align-items:center;text-align:center;">
        <div style="display:flex;align-items:center;justify-content:space-between;width:100%;margin:2px 0 14px;"><span style="color:var(--ink-3);font-size:16px;">⌄</span><span style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;color:var(--ink-3);">NOW PLAYING</span><span style="color:var(--accent);">♥</span></div>
        <img class="aa-cover" src="/assets/pod-tkp.jpg" style="width:196px;height:196px;border-radius:18px;box-shadow:0 22px 46px -16px rgba(26,22,20,0.4);">
        <div style="font-size:15px;font-weight:700;letter-spacing:-0.02em;line-height:1.2;margin-top:16px;">Build the right thing, not just build the thing right</div>
        <div style="font-size:11px;color:var(--accent-ink);font-weight:600;margin-top:6px;">The Knowledge Project · Shane Parrish</div>
        <div style="width:100%;margin-top:14px;"><div style="height:4px;background:var(--cream-3);border-radius:2px;position:relative;"><div style="position:absolute;left:0;top:0;bottom:0;width:34%;background:var(--accent);border-radius:2px;"></div><div style="position:absolute;left:34%;top:50%;transform:translate(-50%,-50%);width:11px;height:11px;border-radius:50%;background:var(--accent);"></div></div><div style="display:flex;justify-content:space-between;font-family:var(--mono);font-size:9px;color:var(--ink-3);margin-top:5px;"><span>17:41</span><span>−34:19</span></div></div>
        <div style="display:flex;align-items:center;gap:18px;margin-top:14px;"><span style="color:var(--ink-2);font-size:13px;">↺15</span><span style="font-size:18px;">⏮</span><span style="width:54px;height:54px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px;">▶</span><span style="font-size:18px;">⏭</span><span style="color:var(--ink-2);font-size:13px;">30↻</span></div>
      </div><div style="height:12px;"></div>`},

    /* 5 · TRANSCRIPT */
    { screen: `${sb}<div class="aa-pad">

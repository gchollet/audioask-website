    const d = document.createElement('i'); dotsEl.appendChild(d);
  });
  const screens = [...scrEl.children], dots = [...dotsEl.children];
  scrEl.setAttribute('data-js', '');

  let idx = 0, timer = null, playing = false;
  function render() {
    screens.forEach(function (e, i) { e.classList.toggle('on', i === idx); });
    dots.forEach(function (e, i) { e.classList.toggle('on', i === idx); });
  }
  function go(n) { idx = (n + screens.length) % screens.length; render(); }
  function play() { playing = true; clearInterval(timer); timer = setInterval(function () { go(idx + 1); }, AA_CONFIG.screenMs); }
  function pause() { playing = false; clearInterval(timer); }

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  go(0);

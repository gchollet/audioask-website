  <div class="container" style="max-width: 820px;">
    <h2>Hosting</h2>
    <p>
      <strong>Infomaniak Network SA</strong><br>
      Rue Eugène-Marziano 25<br>
      1227 Les Acacias, Geneva<br>
      Switzerland<br>
      <a href="https://www.infomaniak.com" target="_blank" rel="noopener">infomaniak.com</a>
    </p>

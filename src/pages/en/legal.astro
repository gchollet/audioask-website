---
import Layout from '../../layouts/Layout.astro';
---

<style>
  .section h2 { margin-bottom: 20px; }
</style>

<Layout
  title="Legal notice — Audioask"
  description="Legal information about the Audioask website and application: publisher Natives Sàrl (Carouge, Geneva), hosting, intellectual property."
  lang="en"
  alternatePath="/mentions-legales"
>

<section class="hero" style="padding-top: 80px; padding-bottom: 60px; min-height: auto;">
  <div class="container">
    <div class="hero-copy" style="max-width: 720px;">
      <p class="eyebrow">Legal</p>
      <h1 style="font-size: clamp(2rem, 4vw, 2.8rem);">Legal notice</h1>
      <p class="lede">Legal information about the publication and hosting of audioask.ai and the Audioask application.</p>
    </div>
  </div>
</section>

<section class="section paper">
  <div class="container" style="max-width: 820px;">
    <h2>Publisher</h2>
    <p>
      <strong>Natives Sàrl</strong><br>
      Carouge, Canton of Geneva<br>
      Switzerland
    </p>
    <p>
      Website: <a href="https://audioask.ai">audioask.ai</a><br>
      Application: <a href="https://dev-app.audioask.ai">dev-app.audioask.ai</a><br>
      Contact: <a href="/en/contact">audioask.ai/en/contact</a>

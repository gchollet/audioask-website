---
import Layout from '../../../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---

<Layout
  title="Translate any podcast — 12 languages — Audioask"
  description="Coming soon: translate any podcast episode into 12 languages. Translated transcript, dubbed audio, voice selection. Built for global content."
  activePage="features"
  lang="en"
  alternatePath="/fonctionnalites/traduire"
>

<!-- HERO -->
<section class="hero dotbg">
  <div class="container" style="max-width: 800px; text-align: center;">
    <div class="eyebrow" style="justify-content: center;"><span class="dot">●</span> Translate <span style="margin-left: 8px; font-family: var(--mono); font-size: 10px; padding: 3px 9px; background: var(--ink); color: var(--cream); border-radius: 999px; letter-spacing: 0.06em;">COMING SOON</span></div>
    <h1 style="margin-top: 18px;">Your podcasts,<br><span class="em-serif">in 12 languages.</span></h1>
    <p class="lede" style="margin: 20px auto 0; max-width: 54ch;">Transcript translated. Audio dubbed with natural voice. No language should be a barrier to great content.</p>
    <div class="hero-ctas" style="justify-content: center; margin-top: 36px;">
      <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Join the waitlist <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<!-- LANGUAGES GRID -->
<section class="section paper">
  <div class="container" style="max-width: 820px;">
    <div class="eyebrow center"><span class="dot">●</span> Languages at launch</div>
    <h2 style="text-align: center; margin-top: 16px;">12 languages.<br><span class="serif-it">Global reach.</span></h2>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 48px;">
      {[
        { flag: "🇫🇷", lang: "French" },
        { flag: "🇬🇧", lang: "English" },
        { flag: "🇩🇪", lang: "German" },
        { flag: "🇪🇸", lang: "Spanish" },
        { flag: "🇮🇹", lang: "Italian" },
        { flag: "🇵🇹", lang: "Portuguese" },
        { flag: "🇳🇱", lang: "Dutch" },
        { flag: "🇵🇱", lang: "Polish" },
        { flag: "🇷🇺", lang: "Russian" },
        { flag: "🇯🇵", lang: "Japanese" },
        { flag: "🇰🇷", lang: "Korean" },
        { flag: "🇨🇳", lang: "Chinese" },
      ].map(l => (
        <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 12px; padding: 16px; display: flex; align-items: center; gap: 10px; font-size: 14px;">
          <span style="font-size: 20px;">{l.flag}</span>
          <span>{l.lang}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="section">
  <div class="container">
    <div class="eyebrow center"><span class="dot">●</span> What's included</div>
    <h2 style="text-align: center; margin-top: 16px;">More than translation —<br><span class="serif-it">a real dubbing experience.</span></h2>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px;">
      <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 28px;">
        <div class="feat-ico" style="margin-bottom: 16px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h12M9 3v3M11 12L7 6 3 12M14 15l5 5M19 20l-3-5-3 5M16 11h6"/></svg>
        </div>
        <h3>Collaborative translation model</h3>
        <p style="color: var(--ink-2); font-size: 14px; line-height: 1.6;">When a member translates an episode, it's shared with the community — just like transcriptions. Translation credits go further when the effort is shared.</p>
      </div>
      <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 28px;">
        <div class="feat-ico" style="margin-bottom: 16px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <h3>Dubbed audio</h3>
        <p style="color: var(--ink-2); font-size: 14px; line-height: 1.6;">Listen to your episode in the target language with natural synthetic voice. Timestamps stay perfectly synced with the original audio.</p>
      </div>
      <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 28px;">
        <div class="feat-ico" style="margin-bottom: 16px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a3 3 0 013 3v6a3 3 0 01-6 0V5a3 3 0 013-3z"/><path d="M19 10a7 7 0 01-14 0"/><path d="M12 19v3M8 22h8"/></svg>
        </div>
        <h3>Voice selection</h3>
        <p style="color: var(--ink-2); font-size: 14px; line-height: 1.6;">Choose from multiple voice options for dubbed audio. Male, female, neutral — in the tone that fits the content.</p>
      </div>
    </div>
  </div>
</section>

<!-- AUTOMATION BONUS -->
<section class="section dark">
  <div class="container" style="max-width: 760px; text-align: center;">
    <div class="eyebrow" style="color: var(--accent); justify-content: center;"><span class="dot">●</span> Coming with automation</div>
    <h2 style="margin-top: 16px;">Auto-translate every<br><span class="serif-it">new episode.</span></h2>
    <p class="lede" style="margin: 20px auto 0; max-width: 52ch; color: var(--night-text-2);">Combine translation with automation: any new episode is transcribed, translated into your language of choice, and delivered — no intervention needed.</p>
    <div style="margin-top: 36px;">
      <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Be notified at launch <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<style>
@media (max-width: 768px) {
  [style*="grid-template-columns: repeat(4"] { grid-template-columns: repeat(2, 1fr) !important; }
  [style*="grid-template-columns: repeat(3"] { grid-template-columns: 1fr !important; }
}
</style>
</Layout>

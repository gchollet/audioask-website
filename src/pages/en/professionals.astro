<script>
// --- Animated Pro feature tour (auto-cycling + clickable)
(function () {
  const tour = document.getElementById('pro-tour');
  if (!tour) return;
  const tabs = [...tour.querySelectorAll('.pro-tour-tab')];
  const scenes = [...tour.querySelectorAll('.pro-scene')];
  const DUR = 4600;
  let idx = 0, timer = null;
  tour.style.setProperty('--tour-dur', DUR + 'ms');

  function show(n, restart) {
    idx = n;
    tabs.forEach((t, i) => t.classList.toggle('on', i === n));
    // re-trigger the rail progress animation by reflow
    const onTab = tabs[n];
    if (onTab) { const p = onTab.querySelector('.prog'); if (p) { p.style.display = 'none'; void p.offsetWidth; p.style.display = ''; } }
    scenes.forEach((s, i) => s.classList.toggle('on', i === n));
    if (restart !== false) schedule();
  }
  function schedule() {
    clearTimeout(timer);
    timer = setTimeout(() => show((idx + 1) % scenes.length), DUR);
  }
  tabs.forEach((t, i) => t.addEventListener('click', () => show(i)));
  show(0);
})();

const PERSONAS = [
  {
    title: 'Keep a complete history of your episodes — and exploit it.',
    body: 'Your entire back-catalog becomes a searchable library: find a quote across 200 episodes, pull up a season 2 topic in 10 seconds, fuel your newsletters from your own archive. Nothing ever gets lost.',
    quote: '« We indexed 380 episodes in 2 weeks. Our back-catalog is no longer a graveyard, it\'s an asset. »',
    quoteFrom: 'Editor · daily podcast',
    illuLabel: 'INDEXED CATALOG',
    illuStat: '380 episodes · 142h audio',
  },
  {
    title: 'Monitor your clients — without listening to 40 hours a week.',
    body: 'Every time one of your clients (or their competitors) is mentioned in a podcast, you know about it. Brand monitoring, timestamped citations, automated competitive intelligence. Your consultants deliver in hours what used to take days.',
    quote: '« My consultants can focus on thinking again. No more re-listening to track a quote. »',
    quoteFrom: 'Director · communications agency',
    illuLabel: 'CLIENT MENTIONS · 7 DAYS',
    illuStat: '42 mentions · 14 podcasts',
  },
  {
    title: 'Quote precisely. Fact-check in 10 seconds.',
    body: 'Fact-checking, timestamped citations, traceable sources. Every sentence in your article can be traced to the second in the interview.',
    quote: '« Not a single approximate citation since we started using Audioask. »',
    quoteFrom: 'Editor-in-chief · independent media',
    illuLabel: 'TIMESTAMPED CITATIONS',
    illuStat: '14 sources · 1 article',
  },
];

function renderPersona(i) {
  const p = PERSONAS[i];
  document.getElementById('persona-pane').innerHTML = `
    <div>
      <div class="eyebrow"><span style="color: var(--accent);">0${i+1}</span> · Persona</div>
      <h3 style="font-size: 30px; margin-top: 14px; max-width: 22ch;">${p.title}</h3>
      <p style="color: var(--ink-2); margin-top: 16px; max-width: 50ch; font-size: 16px;">${p.body}</p>
      <div class="persona-quote">${p.quote}<div style="font-family: var(--sans); font-size: 12px; color: var(--ink-3); font-style: normal; margin-top: 8px; letter-spacing: 0;">— ${p.quoteFrom}</div></div>
    </div>
    <div style="background: var(--cream-2); border-radius: 18px; padding: 28px; aspect-ratio: 5/4; position: relative; border: 1px solid var(--line);">
      <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">${p.illuLabel}</div>
      <div style="margin-top: 14px; font-family: var(--serif); font-size: 38px; line-height: 1.05; letter-spacing: -0.03em; color: var(--accent-ink);">${p.illuStat}</div>
      <div style="position: absolute; bottom: 28px; left: 28px; right: 28px; padding: 14px; background: var(--paper); border: 1px solid var(--line); border-radius: 12px;">
        <div style="font-family: var(--mono); font-size: 9px; color: var(--ink-3); letter-spacing: 0.08em;">ACTIVE AUTOMATION</div>
        <div style="margin-top: 6px; font-size: 13px; color: var(--ink);">Each new episode → processed automatically.</div>
      </div>
    </div>
  `;
}
renderPersona(0);
document.querySelectorAll('.persona-tabs button').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.persona-tabs button').forEach(x => x.classList.remove('on'));
    b.classList.add('on');
    renderPersona(+b.dataset.tab);
  });
});
</script>

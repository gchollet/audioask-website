---
import Layout from '../../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---
<Layout title="Audioask Pro — The plan for podcast professionals" description="Pro plan: transcription at scale, cross-episode AI, unlimited automations, saved prompts. €19/month + usage." activePage="pro" lang="en" alternatePath="/pro">

  <!-- HERO -->
  <section class="hero dotbg">
    <div class="container">
      <div class="hero-copy">
        <div class="hero-eyebrow">
          <span class="pill">PRO</span>
          <span>€19/month + usage · 20h transcription &amp; 25M AI characters included</span>
        </div>
        <h1>
          Audioask on <span class="em-serif">steroids</span>:<br>
          the pro plan.
        </h1>
        <p class="lede">
          For teams who want to unlock all the knowledge podcasts have to offer. Transcription at scale, cross-episode AI, unlimited automations.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary lg" href={`${APP_URL}/signup?plan=pro`}>Start Pro plan <span class="arrow">→</span></a>
          <a class="btn lg" href="/en/pricing">See pricing</a>
        </div>
        <div class="hero-meta">
          <span class="dotcheck">Transparent billing</span>
          <span class="dotcheck">No commitment</span>
        </div>
      </div>

      <!-- Animated feature tour -->
      <div class="product-stage" style="margin-top: 60px;">
        <div class="app-card pro-tour" id="pro-tour">
          <div class="app-toolbar">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            <span class="url">audioask.ai · pro plan</span>
          </div>
          <div class="pro-tour-body">
            <aside class="pro-tour-rail">
              <button class="pro-tour-tab on" data-scene="0">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h11l3 3v13H5z"/><path d="M9 9h6M9 13h6M9 17h3"/></svg></span>
                <span><b>Unlimited prompts</b><small>saved &amp; reusable</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="1">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/></svg></span>
                <span><b>Cross-episode AI</b><small>entire channel</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="2">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg></span>
                <span><b>Automations</b><small>unlimited</small></span>
                <span class="prog"></span>
              </button>
              <button class="pro-tour-tab" data-scene="3">
                <span class="ico"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 5h18v12H3z"/><path d="M8 21h8M9 9l3 2-3 2"/></svg></span>
                <span><b>Widget Embed</b><small>AI on your site</small></span>
                <span class="prog"></span>
              </button>
            </aside>

            <div class="pro-tour-stage">
              <!-- SCENE 0 · Unlimited prompts -->
              <div class="pro-scene on" data-scene="0">
                <div class="pro-scene-head">
                  <span class="lbl">MY SAVED PROMPTS · 12</span>
                  <span class="chip accent-soft" style="font-size: 11px;">∞ UNLIMITED</span>
                </div>
                <div class="stagger s1 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px; border-color: var(--accent);">
                  <span style="color: var(--accent);">★</span>
                  <span style="flex: 1; font-size: 13px;">Client brief — angles &amp; insights</span>
                  <span class="chip accent-soft" style="height: 22px; font-size: 10.5px; padding: 0 8px;">▶ Run</span>
                </div>
                <div class="stagger s2 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">5-point executive summary</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">42×</span>
                </div>
                <div class="stagger s3 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">Timestamped key quotes</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">31×</span>
                </div>
                <div class="stagger s4 tour-prow" style="display: flex; gap: 10px; align-items: center; padding: 11px 14px;">
                  <span style="color: var(--ink-3);">○</span>
                  <span style="flex: 1; font-size: 13px;">Fact-check — sources &amp; figures</span>
                  <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">14×</span>
                </div>
                <div style="margin-top: 12px; font-size: 12px; color: var(--accent-ink); display: flex; align-items: center; gap: 8px;"><span>+</span> New prompt — no limit</div>
              </div>

              <!-- SCENE 1 · Cross-episode AI -->
              <div class="pro-scene" data-scene="1">
                <div class="pro-scene-head">
                  <span class="lbl">Audioask · 142 episodes queried</span>
                  <span class="chip" style="font-size: 11px;">CHANNEL · ACQUIRED</span>
                </div>
                <div class="ai-reveal r1 ai-bubble q" style="background: var(--cream-2); align-self: flex-end; max-width: 80%; margin-left: auto; padding: 11px 14px; border-radius: 14px 14px 4px 14px; font-size: 13px;">
                  How has the hosts' thesis on AI evolved across 3 seasons?
                </div>
                <div class="ai-reveal r2" style="margin-top: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px 14px 14px 4px; padding: 14px 16px; font-size: 13px; line-height: 1.55;">
                  <div>In <b>S1</b>, AI is seen as a risky bet. In <b>S2</b>, it becomes the central thread. In <b>S3</b>, it's the core investment thesis.</div>
                  <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--line-2); font-size: 11px; color: var(--ink-3); display: flex; gap: 8px; flex-wrap: wrap;">
                    <span>↩ 6 citations ·</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#88 · 1:12:04</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#104 · 41:18</span>
                    <span style="font-family: var(--mono); color: var(--accent-ink);">#119 · 52:10</span>
                  </div>
                </div>
              </div>

              <!-- SCENE 2 · Automations -->
              <div class="pro-scene" data-scene="2">
                <div class="pro-scene-head">
                  <span class="lbl">Configure automation · Acquired</span>
                  <span class="chip accent" style="font-size: 11px;">⚡ AUTO</span>
                </div>
                <div class="stagger s1 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">⚡</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Automation</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--accent); position: relative;"><span style="position: absolute; top: 2px; right: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
                <div class="stagger s2 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✦</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Applied prompt</span>
                  <span class="chip" style="height: 24px; font-size: 11px; padding: 0 10px; background: var(--cream-2); border-color: var(--line);">Client brief ▾</span>
                </div>
                <div class="stagger s3 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✉</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Send by email</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--accent); position: relative;"><span style="position: absolute; top: 2px; right: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
                <div class="stagger s4 tour-prow" style="display: flex; gap: 11px; align-items: center; padding: 11px 14px;">
                  <span style="width: 28px; height: 28px; border-radius: 8px; background: var(--cream-2); color: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">📚</span>
                  <span style="flex: 1; font-size: 13px; font-weight: 600;">Save result</span>
                  <span style="width: 38px; height: 21px; border-radius: 999px; background: var(--cream-3); position: relative;"><span style="position: absolute; top: 2px; left: 2px; width: 17px; height: 17px; border-radius: 50%; background: white;"></span></span>
                </div>
              </div>

              <!-- SCENE 3 · Widget Embed -->
              <div class="pro-scene" data-scene="3">
                <div class="pro-scene-head">
                  <span class="lbl">Embedded widget · your site</span>
                  <span class="chip accent-soft" style="font-size: 11px;">NEW</span>
                </div>
                <div class="embed-browser">
                  <div class="bar"><span class="d"></span><span class="d"></span><span class="d"></span><span class="addr">🔒 yoursite.com/podcast</span></div>
                  <div class="embed-site" style="display: flex; flex-direction: column; gap: 10px;">
                    <div class="skel" style="width: 42%;"></div>
                    <div class="embed-widget">
                      <div style="display: flex; align-items: center; gap: 10px;">
                        <img src="/assets/acquired-cover.jpg" alt="" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;">
                        <div style="flex: 1; min-width: 0;"><div style="font-size: 12.5px; font-weight: 600;">#119 — Nvidia</div><div style="font-size: 11px; color: var(--ink-3);">Acquired</div></div>
                        <span style="width: 30px; height: 30px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 11px;">▶</span>
                      </div>
                      <div style="margin-top: 10px; height: 4px; background: var(--cream-2); border-radius: 2px; position: relative;"><div style="position: absolute; left: 0; top: 0; bottom: 0; width: 34%; background: var(--accent); border-radius: 2px;"></div></div>
                      <div style="margin-top: 10px; background: var(--cream); border: 1px solid var(--line); border-radius: 8px; padding: 7px 11px; font-size: 11.5px; color: var(--ink-3); display: flex; align-items: center; gap: 8px;">
                        <span style="color: var(--accent);">✦</span> Ask a question about this episode…
                        <span style="margin-left: auto; font-family: var(--mono); font-size: 9px; background: var(--accent-tint); color: var(--accent-ink); padding: 2px 6px; border-radius: 4px;">AI</span>
                      </div>
                    </div>
                    <div class="skel" style="width: 88%;"></div>
                    <div class="skel" style="width: 64%;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES — alternating blocks -->
  <section class="section paper">
    <div class="container">
      <div class="row between" style="align-items: flex-end; flex-wrap: wrap; gap: 32px;">
        <div>
          <div class="eyebrow"><span class="dot">●</span> The full arsenal</div>
          <h2 style="margin-top: 16px;">Everything you need
to unlock the value of your podcasts.</h2>
        </div>
        <p class="lede" style="max-width: 38ch;">Features designed to extract value from your podcasts and the ones you follow.</p>
      </div>

      <!-- Feature 1 : Cross-episode AI -->
      <div class="feature-alt" style="margin-top: 48px;">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">01</span> · Cross-episode AI</div>
          <h3 style="margin-top: 12px;">Query an entire channel, not just one episode.</h3>
          <p>Ask a question across an entire podcast — all seasons combined. Trends, guest comparisons, evolution over time. Every answer is cited and timestamped.</p>
          <div style="margin-top: 24px; display: flex; align-items: baseline; gap: 12px;">
            <span style="font-family: var(--serif); font-size: 44px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">25M</span>
            <span style="font-size: 14px; color: var(--ink-3);">AI characters included / month</span>
          </div>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">142 EPISODES QUERIED · ACQUIRED</div>
          <div style="background: var(--cream-2); border-radius: 14px 14px 4px 14px; padding: 11px 14px; font-size: 13px; max-width: 82%; margin-left: auto;">
            How has the hosts' thesis on AI evolved across 3 seasons?
          </div>
          <div style="margin-top: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px 14px 14px 4px; padding: 14px 16px; font-size: 13px; line-height: 1.55;">
            <div>In <b>S1</b>, AI is seen as a risky bet. In <b>S2</b>, it becomes the central thread. In <b>S3</b>, it's the core investment thesis.</div>
            <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--line-2); font-size: 11px; color: var(--ink-3); display: flex; gap: 8px; flex-wrap: wrap;">
              <span>↩ 6 citations ·</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#88 · 1:12:04</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#104 · 41:18</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">#119 · 52:10</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 2 : Unlimited prompts -->
      <div class="feature-alt reverse">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">02</span> · Unlimited prompts</div>
          <h3 style="margin-top: 12px;">Your prompts, saved and reusable indefinitely.</h3>
          <p>Create, name, and save as many prompts as you want: client brief, executive summary, quote extraction… Apply them in one click to any episode or channel.</p>
          <div style="margin-top: 24px; display: flex; align-items: baseline; gap: 12px;">
            <span style="font-family: var(--serif); font-size: 44px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">∞</span>
            <span style="font-size: 14px; color: var(--ink-3);">custom &amp; shared prompts</span>
          </div>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto; display: flex; flex-direction: column; gap: 8px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 4px;">MY SAVED PROMPTS · 12</div>
          <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--accent);">★</span>
            <span style="flex: 1;">Client brief — angles &amp; actionable insights</span>
            <span class="chip accent-soft" style="height: 22px; font-size: 10.5px; padding: 0 8px;">▶ Run</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">5-point executive summary</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 42×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Timestamped key quotes</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 31×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Books &amp; tools mentioned</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 19×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Fact-check — sources &amp; figures</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 14×</span>
          </div>
          <div style="margin-top: 2px; font-size: 11.5px; color: var(--accent-ink); display: flex; align-items: center; gap: 8px;"><span>+</span> New prompt — no limit</div>
        </div>
      </div>

      <!-- Feature 3 : Automations -->
      <div class="feature-alt">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">03</span> · Automations</div>
          <h3 style="margin-top: 12px;">Unlimited automations, delivered where you want.</h3>
          <p>Every new episode triggers your workflow: transcription, custom prompt, then automatic delivery (email, Slack, webhook). Set it up once, it runs all year.</p>
          <a href="/en/features/automate" class="btn btn-primary" style="margin-top: 20px; display: inline-flex;">Learn more <span class="arrow" style="margin-left: 6px;">→</span></a>
        </div>
        <div class="demo" style="padding: 22px; aspect-ratio: auto;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">CONFIGURE AUTOMATION · ACQUIRED</div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">⚡</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Automation</div><div style="font-size: 11px; color: var(--ink-3);">Process each new episode</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--accent); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✦</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Applied prompt</div><div style="font-size: 11px; color: var(--ink-3);">Choose from your prompts</div></div>
              <span class="chip" style="height: 26px; font-size: 11.5px; padding: 0 11px; background: var(--cream-2); border-color: var(--line);">Client brief ▾</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--accent-tint); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">✉</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Send by email</div><div style="font-size: 11px; color: var(--ink-3);">As soon as the result is ready</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--accent); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
              <span style="width: 30px; height: 30px; border-radius: 8px; background: var(--cream-2); color: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">📚</span>
              <div style="flex: 1; min-width: 0;"><div style="font-size: 13px; font-weight: 600;">Save result</div><div style="font-size: 11px; color: var(--ink-3);">In your library</div></div>
              <span style="width: 40px; height: 22px; border-radius: 999px; background: var(--cream-3); position: relative; flex-shrink: 0;"><span style="position: absolute; top: 2px; left: 2px; width: 18px; height: 18px; border-radius: 50%; background: white;"></span></span>
            </div>
          </div>
          <div style="margin-top: 12px; display: flex; justify-content: flex-end; gap: 8px;">
            <span class="chip" style="height: 30px; font-size: 12.5px; padding: 0 13px;">Cancel</span>
            <span class="chip accent" style="height: 30px; font-size: 12.5px; padding: 0 13px;">✓ Save</span>
          </div>
        </div>
      </div>

      <!-- Feature 4 : Widget Embed (NEW) -->
      <div class="feature-alt reverse" style="background: var(--cream-2); border-radius: 24px; padding: 48px; margin-top: 32px; border: 1px solid var(--line);">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 10px;">
            <span style="background: var(--accent); color: white; padding: 4px 10px; border-radius: 999px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;">NEW</span>
            <span class="eyebrow"><span style="color: var(--accent);">04</span> · Widget Embed</span>
          </div>
          <h3 style="margin-top: 16px;">Your podcast on your site, with integrated AI.</h3>
          <p>Drop a smart player onto any page — in two minutes, without a developer. Your visitors listen, read the transcript, and ask the AI questions, without ever leaving your site.</p>
          <div class="embed-chips" style="margin-top: 20px;">
            <span>🎨 Your brand colors</span>
            <span>🔍 Full-text search</span>
            <span>🤖 Capped AI spend</span>

---
import Layout from '../../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---

<Layout
  title="About — Audioask"
  description="Audioask was born from a simple observation: podcast content is an incredibly rich source of knowledge, yet rarely easy to use. Built and operated from Switzerland."
  activePage="a-propos"
  lang="en"
  alternatePath="/a-propos"
>

  <!-- HERO -->
  <section class="hero dotbg">
    <div class="container">
      <div class="about-hero-grid" style="display: grid; grid-template-columns: 1.1fr 1fr; gap: 64px; align-items: center;">
        <div>
          <div class="page-intro">About</div>
          <h1 style="text-align: left;">
            Building <span class="em-serif">the tool</span><br>we always wished existed.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            Audioask was born from a simple observation: podcast content is an incredibly rich source of knowledge, yet rarely easy to use.
          </p>
        </div>
        <!-- Editorial composition -->
        <div class="about-hero-deco" style="position: relative; aspect-ratio: 5/4;">
          <div style="position: absolute; inset: 0;">
            <div style="position: absolute; top: 0; right: 0; width: 70%; aspect-ratio: 1; background: var(--accent-tint); border-radius: 24px;"></div>
            <div style="position: absolute; bottom: 0; left: 0; width: 60%; aspect-ratio: 4/5; background: var(--paper); border: 1px solid var(--line); border-radius: 24px; padding: 22px; box-shadow: var(--shadow-md); display: flex; flex-direction: column;">
              <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">NOTEBOOK · 2024</div>
              <div style="margin-top: 14px; font-family: var(--serif); font-size: 28px; line-height: 1.2; letter-spacing: -0.02em;">« Why can't you search in a podcast the way you search in a book? »</div>
              <div style="margin-top: auto; font-size: 12px; color: var(--ink-3);">— A founder's note</div>
            </div>
            <div style="position: absolute; top: 16%; right: 6%; width: 48%; padding: 16px 18px; background: var(--paper); border: 1px solid var(--line); border-radius: 16px; box-shadow: var(--shadow-md); transform: rotate(3deg);">
              <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 8px;">PROTOTYPE V0 · MAY 2024</div>
              <div style="height: 4px; background: var(--cream-2); border-radius: 2px; position: relative;"><div style="position: absolute; left: 0; top: 0; bottom: 0; width: 48%; background: var(--accent); border-radius: 2px;"></div></div>
              <div style="font-size: 11px; color: var(--ink-2); margin-top: 8px;">« First transcription in 4min 12s »</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR STORY -->
  <section class="section paper">
    <div class="container">
      <div class="about-story-grid" style="display: grid; grid-template-columns: 1.1fr 1fr; gap: 80px; align-items: center;">
        <div>
          <div class="eyebrow"><span class="dot">●</span> Our story</div>
          <h2 style="margin-top: 16px;">Making podcasts a knowledge base <span class="serif-it">more accessible.</span></h2>
          <p class="lede" style="margin-top: 20px;">Podcasts have become one of today's richest formats: interviews, analyses, firsthand accounts, debates. But this knowledge remains trapped in audio — hard to search, quote, or share.</p>
          <p style="margin-top: 14px; color: var(--ink-2); font-size: 16px; max-width: 56ch;">Audioask unlocks that content. Transcription, translation, AI: podcasts become a real library, as searchable and reusable as text.</p>
        </div>
        <div style="background: var(--cream-2); border-radius: 24px; padding: 32px; position: relative; aspect-ratio: 1;">
          <div style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.08em;">TIMELINE</div>
          <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 18px;">
            <div style="display: grid; grid-template-columns: 72px 1fr; gap: 14px;">
              <span style="font-family: var(--mono); font-size: 12px; color: var(--accent-ink);">2024 · Q1</span>
              <span style="font-size: 14px; color: var(--ink); line-height: 1.4;"><b>Prototype</b> — first Audioask transcription, on a 28-min episode.</span>
            </div>
            <div style="display: grid; grid-template-columns: 72px 1fr; gap: 14px;">
              <span style="font-family: var(--mono); font-size: 12px; color: var(--accent-ink);">2025 · Q2</span>
              <span style="font-size: 14px; color: var(--ink); line-height: 1.4;"><b>Private beta</b> — 50 users, 1,200 transcribed episodes.</span>
            </div>
            <div style="display: grid; grid-template-columns: 72px 1fr; gap: 14px;">
              <span style="font-family: var(--mono); font-size: 12px; color: var(--accent-ink);">2025 · Q4</span>
              <span style="font-size: 14px; color: var(--ink); line-height: 1.4;"><b>Public launch</b> — Free, Premium, Pro.</span>
            </div>
            <div style="display: grid; grid-template-columns: 72px 1fr; gap: 14px;">
              <span style="font-family: var(--mono); font-size: 12px; color: var(--accent);">2026 →</span>
              <span style="font-size: 14px; color: var(--ink); line-height: 1.4;"><b>Shared library</b> — +185M episodes available.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION (large) -->
  <section class="section alt xl" style="text-align: center;">
    <div class="container">
      <div class="eyebrow" style="justify-content: center; display: inline-flex;"><span class="dot">●</span> Our mission</div>
      <p class="mission-bg" style="margin-top: 24px;">
        Making audio knowledge as <em>accessible</em> and <em>usable</em> as text.
      </p>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section">
    <div class="container">
      <div style="max-width: 720px;">
        <div class="eyebrow"><span class="dot">●</span> Our values</div>
        <h2 style="margin-top: 16px;">Four principles,<br><span class="serif-it">upheld every day.</span></h2>
      </div>
      <div class="about-values-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 48px;">
        <div class="value-card">
          <div class="val-num">01 · Made in Switzerland 🇨🇭</div>
          <h3>Swiss made, for real.</h3>
          <p>Audioask is developed and operated from Switzerland. Our standards of quality, privacy, and reliability are those you'd expect from a Swiss product.</p>
        </div>
        <div class="value-card">
          <div class="val-num">02 · Knowledge</div>
          <h3>Giving access to more knowledge.</h3>
          <p>The knowledge produced every day in audio should benefit as many people as possible — not just those with 10 free hours a week. That's what we're building: making listening and knowledge compatible with real life.</p>
        </div>
        <div class="value-card">
          <div class="val-num">03 · Community</div>
          <h3>The power of community.</h3>
          <p>Every transcription created by one user benefits the whole community. That's our vision of useful software: precious for the individual, powerful for the group.</p>
        </div>
        <div class="value-card">
          <div class="val-num">04 · Simplicity</div>
          <h3>Simplicity first.</h3>
          <p>We build tools that do one thing, and do it very well. No unnecessary features, no interface that buries what matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING OVERVIEW -->
  <section class="section alt">
    <div class="container">
      <div class="about-tarifs-grid" style="background: var(--paper); border-radius: 24px; padding: 48px; border: 1px solid var(--line); display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center;">
        <div>
          <div class="eyebrow" style="display: inline-flex; align-items: center; gap: 10px;">
            <span style="background: var(--accent); color: white; padding: 3px 10px; border-radius: 999px; font-size: 10px; letter-spacing: 0.08em;">PRICING</span>
            A plan for every use
          </div>
          <h2 style="margin: 16px 0 14px;">Access <span class="serif-it">for every need,</span><br>from curious to professional.</h2>
          <p class="lede" style="font-size: 17px;">From the free plan to €19/month, Audioask adapts to your usage. Whether you listen to 2 podcasts a month or leverage dozens for your work, there's a plan for you.</p>
          <div style="display: flex; gap: 10px; margin-top: 28px; flex-wrap: wrap;">
            <a class="btn btn-primary" href="/en/pricing">Discover pricing <span class="arrow">→</span></a>
            <a class="btn btn-ghost" href={`${APP_URL}/signup`}>Start for free</a>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <div style="padding: 16px 20px; background: var(--cream); border: 1px solid var(--line); border-radius: 14px; display: flex; justify-content: space-between; align-items: center;">
            <div><b>Free</b><div style="font-size: 12px; color: var(--ink-3); margin-top: 2px;">To get started</div></div>
            <div style="font-weight: 600; font-size: 24px; letter-spacing: -0.02em;">€0</div>
          </div>
          <div style="padding: 16px 20px; background: var(--accent-tint); border: 1px solid var(--accent); border-radius: 14px; display: flex; justify-content: space-between; align-items: center;">
            <div><b>Premium</b><div style="font-size: 12px; color: var(--accent-ink); margin-top: 2px;">For enthusiasts · Recommended</div></div>
            <div style="font-weight: 600; font-size: 24px; letter-spacing: -0.02em;">€3<small style="font-size: 12px; font-weight: 400; color: var(--ink-3);">&nbsp;/month</small></div>
          </div>
          <div style="padding: 16px 20px; background: var(--cream); border: 1px solid var(--line); border-radius: 14px; display: flex; justify-content: space-between; align-items: center;">
            <div><b>Pro</b><div style="font-size: 12px; color: var(--ink-3); margin-top: 2px;">For professionals</div></div>
            <div style="font-weight: 600; font-size: 24px; letter-spacing: -0.02em;">€19<small style="font-size: 12px; font-weight: 400; color: var(--ink-3);">&nbsp;/month + usage</small></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section center" style="text-align: center;">
    <div class="container">
      <div class="eyebrow" style="justify-content: center; display: inline-flex;"><span class="dot">●</span> Contact</div>
      <h2 style="margin-top: 16px;">A <span class="serif-it">question</span>?</h2>
      <p class="lede" style="margin: 18px auto 28px; text-align: center;">The Audioask team replies personally.</p>
      <a href="/en/contact" class="btn btn-ghost lg" style="font-family: var(--mono); font-size: 14px;">✉ Contact us</a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section dark cta-final">
    <div class="container">
      <h2>Join the community<br>that's <span class="em-serif">reinventing</span> podcast listening.</h2>
      <a class="btn btn-primary lg" href={`${APP_URL}/signup`} style="margin-top: 12px; height: 56px; font-size: 16px; padding: 0 28px;">Create a free account <span class="arrow">→</span></a>
    </div>
  </section>


<style>
  /* Responsive overrides */
  @media (max-width: 768px) {
    .about-hero-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
    .about-hero-deco { display: none; }
    .about-story-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
    .about-values-grid { grid-template-columns: 1fr !important; }
    .about-tarifs-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .mission-bg { font-size: clamp(32px, 9vw, 48px) !important; }
  }
</style>

</Layout>

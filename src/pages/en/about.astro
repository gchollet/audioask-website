---
import Layout from '../../layouts/Layout.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---

<Layout
  title="About Audioask — Our mission and story"
  description="Audioask was built to make audio knowledge as accessible and usable as text. A Swiss indie project, launched in 2025."
  activePage="a-propos"
  lang="en"
  alternatePath="/a-propos"
>

<!-- HERO -->
<section class="hero dotbg">
  <div class="container" style="max-width: 760px; text-align: center;">
    <div class="eyebrow" style="justify-content: center;"><span class="dot">●</span> About</div>
    <h1 style="margin-top: 18px;">Making audio knowledge<br><span class="em-serif">as usable as text.</span></h1>
    <p class="lede" style="margin: 20px auto 0; max-width: 52ch;">Audioask was built because too much great knowledge gets buried in podcasts — heard once, never found again. We're fixing that.</p>
  </div>
</section>

<!-- STORY / TIMELINE -->
<section class="section paper">
  <div class="container" style="max-width: 760px;">
    <div class="eyebrow"><span class="dot">●</span> Our story</div>
    <h2 style="margin-top: 16px;">Built in the open,<br><span class="serif-it">step by step.</span></h2>
    <div class="timeline" style="margin-top: 48px;">
      {[
        { date: "Q1 2024", label: "First prototype", desc: "A weekend project: basic transcription of a podcast episode. The idea stuck." },
        { date: "Q2 2025", label: "Private beta", desc: "First 100 users. Real feedback, real usage. The product takes its current shape." },
        { date: "Q4 2025", label: "Public launch", desc: "Audioask opens to everyone. Free plan, Premium plan, and Pro plan go live." },
        { date: "2026", label: "Library & mobile", desc: "Community library grows past 185M episodes. Mobile app in development — iOS & Android coming soon." },
      ].map((step, i) => (
        <div class="timeline-item">
          <div class="timeline-date">{step.date}</div>
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h4>{step.label}</h4>
            <p>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- MISSION -->
<section class="section">
  <div class="container" style="max-width: 760px; text-align: center;">
    <div class="eyebrow" style="justify-content: center;"><span class="dot">●</span> Mission</div>
    <h2 style="margin-top: 16px;">Audio knowledge,<br><span class="serif-it">as accessible as text.</span></h2>
    <p style="font-size: 18px; color: var(--ink-2); line-height: 1.8; max-width: 54ch; margin: 24px auto 0;">We believe the best conversations, the sharpest ideas, and the most honest expertise happen in audio. Podcasts are an incredible format — but without text, they're ephemeral. You hear them once, and they're gone. Audioask turns every episode into something you can search, reference, and build on.</p>
  </div>
</section>

<!-- VALUES -->
<section class="section paper">
  <div class="container">
    <div class="eyebrow center"><span class="dot">●</span> Our values</div>
    <h2 style="text-align: center; margin-top: 16px;">What we stand for.</h2>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 48px; max-width: 820px; margin-left: auto; margin-right: auto;">
      {[
        { icon: "🇨🇭", title: "Swiss Made", desc: "Audioask is built and operated by Natives Sàrl, based in Carouge, Geneva. Our data is hosted in the EU, under Swiss and European law." },
        { icon: "📚", title: "Knowledge first", desc: "We build tools that help you learn more, remember more, and do more with what you listen to. Utility over novelty." },
        { icon: "🤝", title: "Community at the core", desc: "The shared library only works because members contribute to it. Every transcript you create helps someone else — and vice versa." },
        { icon: "◻", title: "Simplicity", desc: "We say no to features that add complexity without adding value. Audioask should feel effortless — not like a second job." },
      ].map(v => (
        <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 28px;">
          <div style="font-size: 28px; margin-bottom: 16px;">{v.icon}</div>
          <h3 style="font-size: 18px; margin: 0 0 12px;">{v.title}</h3>
          <p style="color: var(--ink-2); font-size: 14px; line-height: 1.6; margin: 0;">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PRICING TEASER -->
<section class="section">
  <div class="container" style="max-width: 760px; text-align: center;">
    <h2>Try Audioask for free.<br><span class="serif-it">1h of transcription included.</span></h2>
    <p style="color: var(--ink-2); font-size: 16px; line-height: 1.7; max-width: 44ch; margin: 20px auto 32px;">No card needed. Free plan, forever. Upgrade when you're ready.</p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Create a free account <span class="arrow">→</span></a>
      <a class="btn btn-ghost lg" href="/en/pricing">See pricing</a>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section paper">
  <div class="container" style="max-width: 640px; text-align: center;">
    <div class="eyebrow" style="justify-content: center;"><span class="dot">●</span> Get in touch</div>
    <h2 style="margin-top: 16px;">A question? An idea?</h2>
    <p style="color: var(--ink-2); font-size: 15px; line-height: 1.7; margin: 16px 0 28px;">We read every message. Whether it's feedback, a partnership request, or a bug — reach out.</p>
    <a class="btn btn-ghost" href="/en/contact">Contact us <span class="arrow">→</span></a>
  </div>
</section>

<style>
.timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
.timeline::before { content: ''; position: absolute; left: 100px; top: 8px; bottom: 8px; width: 1px; background: var(--line); }
.timeline-item { display: grid; grid-template-columns: 100px 24px 1fr; gap: 0 16px; padding-bottom: 36px; position: relative; }
.timeline-date { font-family: var(--mono); font-size: 11px; color: var(--accent-ink); text-align: right; padding-top: 2px; letter-spacing: 0.04em; }
.timeline-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); border: 2px solid var(--paper); box-shadow: 0 0 0 1px var(--accent); flex-shrink: 0; margin-top: 4px; justify-self: center; }
.timeline-content h4 { font-size: 16px; margin: 0 0 6px; }
.timeline-content p { color: var(--ink-2); font-size: 14px; line-height: 1.6; margin: 0; }
@media (max-width: 640px) {
  [style*="grid-template-columns: repeat(2"] { grid-template-columns: 1fr !important; }
  .timeline-item { grid-template-columns: 70px 20px 1fr; }
  .timeline::before { left: 70px; }
  .timeline-date { font-size: 10px; }
}
</style>
</Layout>

---
import Layout from '../layouts/Layout.astro';
const APP_URL = 'https://app.audioask.ai';
---

<Layout
  title="Audioask — Vos podcasts vous donnent plus."
  description="Audioask donne une nouvelle dimension à vos podcasts. Écoutez, transcrivez, interrogez chaque épisode avec l'IA et exploitez ce que vous écoutez."
  activePage="home"
>

<!-- HERO -->
<section class="hero dotbg">
  <div class="container">
    <div class="hero-copy">
      <div class="hero-eyebrow">
        <span class="pill">Nouveau</span>
        <span>Vos podcasts deviennent une base de connaissances.</span>
      </div>
      <h1 id="hero-h1">
        L'application <span class="em-serif">vraiment</span><br>
        faite pour les amateurs<br>
        de podcasts.
      </h1>
      <p class="lede">Audioask donne une nouvelle dimension à vos podcasts. Écoutez, transcrivez, interrogez chaque épisode avec l'IA et exploitez ce que vous écoutez.</p>
      <div class="hero-ctas">
        <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Essayer gratuitement <span class="arrow">→</span></a>
        <a class="btn lg" href="#">Voir une démo</a>
      </div>
      <div class="hero-meta">
        <span class="dotcheck">Gratuit. Sans carte.</span>
        <span class="dotcheck">1h de transcription offerte</span>
      </div>
    </div>

    <!-- Product mockup stage -->
    <div class="product-stage" id="product-stage">

      <!-- Floating annotations -->
      <div class="float seq" style="top: 38px; left: -8px; max-width: 220px; animation-delay: 0.5s;">
        <span class="lbl">Bibliothèque commune</span>
        <span class="val" style="font-family: var(--serif); font-size: 26px; line-height: 1; color: var(--accent-ink); letter-spacing: -0.02em;">+185M</span>
        <span style="font-size: 12px; color: var(--ink-3);">épisodes déjà accessibles</span>
      </div>

      <div class="float seq" style="top: 220px; left: -28px; max-width: 200px; animation-delay: 1.3s;">
        <span class="lbl">Signet · 12:42</span>
        <span style="font-size: 13px; color: var(--ink); line-height: 1.4;">« On a parié sur CUDA quand personne n'y croyait. »</span>
        <span style="font-size: 11px; color: var(--ink-3); margin-top: 2px;">— Jensen Huang</span>
      </div>

      <div class="float seq" style="top: 110px; right: -16px; max-width: 240px; animation-delay: 2.1s;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="width: 22px; height: 22px; border-radius: 6px; background: var(--accent-soft); color: var(--accent); display: flex; align-items: center; justify-content: center;">⚡</span>
          <span class="lbl" style="margin: 0;">Automation</span>
        </div>
        <span style="font-size: 13px; color: var(--ink); line-height: 1.4;">Chaque nouvel épisode de <b>Acquired</b> sera traité automatiquement.</span>
      </div>

      <div class="float seq" style="bottom: 90px; right: -36px; max-width: 220px; animation-delay: 2.9s;">
        <span class="lbl">Recherche globale</span>
        <span style="font-size: 13px; color: var(--ink); line-height: 1.4;">3 épisodes parlent de <span style="background: var(--accent-soft); padding: 1px 4px; border-radius: 3px; color: var(--accent-ink);">tokenomics</span></span>
      </div>

      <!-- Main app card -->
      <div class="app-card" id="hero-app">
        <div class="app-toolbar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="url">audioask.ai/feed/channel/acquired</span>
        </div>
        <div class="app-shell">
          <!-- Sidebar -->
          <aside class="app-side">
            <div class="brand"><span class="brand-mark">A</span><span>Audioask</span></div>
            <div class="nav">
              <div class="nav-item">
                <svg class="ico" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 4h10M3 8h10M3 12h6"/></svg>
                Feed
              </div>
              <div class="nav-item">
                <svg class="ico" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="7" cy="7" r="4"/><path d="M11 11l3 3"/></svg>
                Recherche
              </div>
              <div class="nav-item on">
                <svg class="ico" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 3v11M5 3v11M9 3l4 11M12 3v11"/></svg>
                My Audioask
              </div>
            </div>
            <div class="group-label">CHANNELS FAVORIS</div>
            <div class="nav">
              <div class="channel on"><img class="ch-cover" src="/assets/pod-acquired.jpg" alt="">Acquired</div>
              <div class="channel"><img class="ch-cover" src="/assets/pod-tkp.jpg" alt="">The Knowledge Project</div>
              <div class="channel"><img class="ch-cover" src="/assets/pod-lex.jpg" alt="">Lex Fridman</div>
              <div class="channel"><img class="ch-cover" src="/assets/pod-huberman.jpg" alt="">Huberman Lab</div>
            </div>
            <div class="group-label">PLAYLISTS</div>
            <div class="nav">
              <div class="channel"><span style="width:14px;height:14px;border-radius:3px;background:rgba(26,22,20,0.10);"></span>Business · 12</div>
              <div class="channel"><span style="width:14px;height:14px;border-radius:3px;background:rgba(26,22,20,0.10);"></span>Pour le trajet · 6</div>
            </div>
          </aside>

          <!-- Main pane -->
          <main class="app-main">
            <div class="crumbs">FEED › CHANNEL · <span class="curr">ACQUIRED</span></div>
            <div class="ep-head">
              <div class="ep-cover" style="padding: 0; overflow: hidden;">
                <img src="/assets/acquired-cover.jpg" alt="Acquired" style="width: 88px; height: 88px; object-fit: cover; display: block; border-radius: 12px;">
              </div>
              <div style="flex: 1; min-width: 0;">
                <div class="ep-title">#119 — Nvidia&nbsp;: la décennie qui change tout</div>
                <div class="ep-author">Ben Gilbert &amp; David Rosenthal · 2h 47min</div>
                <div class="ep-stats">
                  <div class="ep-stat"><b>126</b>passages</div>
                  <div class="ep-stat"><b>2</b>intervenants</div>
                  <div class="ep-stat"><b>4</b>réponses favorites</div>
                  <div class="ep-stat"><b>7</b>signets</div>
                </div>
              </div>
              <div class="ep-actions">
                <span class="chip"><span style="color: var(--ink-3); font-size: 14px;">↗</span>Partager</span>
                <span class="chip accent">✦ Audioask</span>
              </div>
            </div>

            <div class="transcript">
              <div class="t-row">
                <span class="ts">00:00</span>
                <span><span class="speak host">BEN</span>Bienvenue dans cet épisode où nous allons retracer l'histoire de Nvidia, de ses débuts en 1993 à sa position actuelle…</span>
              </div>
              <div class="t-row">
                <span class="ts">04:18</span>
                <span><span class="speak host">DAVID</span>Avant Nvidia, le marché des GPU était dominé par 3DFX, Matrox, ATI…</span>
              </div>
              <div class="t-row bookmarked">
                <span class="ts">12:42</span>
                <span><span class="speak guest">JENSEN</span><span class="quote">« On a parié sur CUDA quand personne n'y croyait. C'est devenu notre fossé concurrentiel le plus profond. »</span></span>
              </div>
              <div class="t-row">
                <span class="ts">19:30</span>
                <span><span class="speak host">BEN</span>Et c'est exactement à ce moment-là que la stratégie a basculé. Le marché des datacenters…</span>
              </div>
              <div class="t-row">
                <span class="ts">28:05</span>
                <span><span class="speak guest">JENSEN</span>Notre conviction&nbsp;: chaque watt utilisé doit servir à accélérer un calcul utile.</span>
              </div>
              <div class="t-row">
                <span class="ts">38:50</span>
                <span><span class="speak host">DAVID</span>Le tournant de 2022, c'est l'explosion de la demande pour l'IA générative…</span>
              </div>
            </div>
          </main>

          <!-- AI panel -->
          <aside class="app-ai">
            <div class="ai-head">
              <span class="ai-spark">✦</span>
              <span class="ai-title">Audioask</span>
              <span style="margin-left: auto; font-size: 10px; color: var(--ink-3); font-family: var(--mono);">SUR CET ÉPISODE</span>
            </div>
            <div class="ai-body">
              <div class="ai-bubble q">Quels sont les 3 paris clés racontés dans cet épisode&nbsp;?</div>
              <div class="ai-bubble a">
                <div><span class="num">1.</span> Le pari sur <b>CUDA</b> en 2006 — investir massivement dans une couche logicielle propriétaire.</div>
                <div style="margin-top: 6px;"><span class="num">2.</span> Le rachat de <b>Mellanox</b> en 2019 pour verrouiller le datacenter.</div>
                <div style="margin-top: 6px;"><span class="num">3.</span> Le bet sur l'<b>IA générative</b> en 2018, deux ans avant ChatGPT.</div>
                <div class="ai-cite">
                  <span>↩</span><span>3 citations · </span><span class="ts">12:42</span><span class="ts">52:10</span><span class="ts">1:47:18</span>
                </div>
              </div>
              <div class="ai-input">
                <span style="color: var(--ink-3);">✎</span>
                <span>Une autre question…</span>
                <span class="send">→</span>
              </div>
            </div>
          </aside>
        </div>

        <!-- Player -->
        <div class="app-player">
          <div class="player-now">
            <img class="cv" src="/assets/pod-acquired.jpg" alt="" style="object-fit:cover;">
            <div>
              <div class="ti">#119 — Nvidia</div>
              <div class="sb">Acquired</div>
            </div>
          </div>
          <div class="player-ctl">
            <span class="player-btn">«</span>
            <span class="player-btn play">▶</span>
            <span class="player-btn">»</span>
            <span class="player-ts">12:42</span>
            <span class="player-bar"><span class="fill"></span><span class="dot" style="left: 30%;"></span></span>
            <span class="player-ts">2:47:01</span>
          </div>
          <div class="player-right">
            <span style="padding: 2px 8px; border-radius: 6px; background: var(--cream-2); color: var(--ink-2);">×1.5</span>
            <span>⋯</span>
          </div>
        </div>
      </div>

      <!-- Float below card -->
      <div class="float seq" style="bottom: -24px; left: 8%; max-width: 200px; animation-delay: 3.7s;">
        <span class="lbl">Transcrit en</span>
        <span class="val" style="font-family: var(--serif); font-size: 28px; line-height: 1; letter-spacing: -0.02em;">2&nbsp;min&nbsp;48</span>
        <span style="font-size: 11px; color: var(--ink-3);">pour 2h 47min d'audio</span>
      </div>
    </div>
  </div>
</section>

<!-- CE QUI CHANGE POUR VOUS -->
<section class="section paper">
  <div class="container">
    <div class="row between" style="align-items: flex-end; gap: 32px; flex-wrap: wrap;">
      <div>
        <div class="eyebrow"><span class="dot">●</span> Ce qui change pour vous</div>
        <h2 style="margin-top: 16px;">Une vraie app de podcasts,<br><span class="serif-it">pensée pour les gens qui écoutent vraiment.</span></h2>
      </div>
      <p class="lede" style="max-width: 36ch;">Ces petites fonctionnalités qui donnent de la valeur à vos podcasts.</p>
    </div>

    <div class="feat-grid">
      <!-- Feature 1 -->
      <div class="feat-card">
        <span class="feat-num">01</span>
        <div class="feat-ico">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z"/><path d="M5 19h6"/></svg>
        </div>
        <h3>Vos prompts préférés enregistrés et prêts au réemploi.</h3>
        <p>Enregistrez les questions que vous posez tout le temps — « résume en 5 points », « quelles citations clés ? ». Un clic, et l'IA répond sur l'épisode, citations à l'appui.</p>
        <div class="feat-visual">
          <div style="position: absolute; inset: 22px; display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--ink-3);">
              <img src="/assets/acquired-cover.jpg" alt="Acquired" style="width: 22px; height: 22px; border-radius: 5px; object-fit: cover;">
              <span>Sur l'épisode <b style="color: var(--ink);">#119 · Nvidia</b></span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 9px; padding: 8px 12px; display: flex; align-items: center; gap: 8px; font-size: 12px;">
              <span style="color: var(--accent);">★</span>
              <span style="flex: 1;">Résumé exécutif · 5 points</span>
              <span class="chip accent" style="height: 20px; padding: 0 8px; font-size: 10px;">▶ Lancer</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 9px; padding: 10px 12px; font-size: 11.5px; line-height: 1.5;">
              <div><span style="color: var(--accent); font-weight: 600;">1.</span> Pari sur <b>CUDA</b> dès 2006.</div>
              <div><span style="color: var(--accent); font-weight: 600;">2.</span> Rachat de <b>Mellanox</b> en 2019.</div>
              <div><span style="color: var(--accent); font-weight: 600;">3.</span> Bet sur l'<b>IA générative</b> en 2018.</div>
              <div style="margin-top: 6px; padding-top: 6px; border-top: 1px dashed var(--line-2); font-size: 10px; color: var(--ink-3); display: flex; gap: 6px;"><span>↩ 3 citations</span><span style="font-family: var(--mono); color: var(--accent-ink);">12:42</span><span style="font-family: var(--mono); color: var(--accent-ink);">52:10</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="feat-card">
        <span class="feat-num">02</span>
        <div class="feat-ico">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h12M4 12h12M4 18h7"/><path d="M18 13l5 3-5 3z"/></svg>
        </div>
        <h3>Vos playlists, vos favoris, votre rythme d'écoute.</h3>
        <p>Organisez vos épisodes en playlists thématiques (business, trajet, weekend). Marquez vos favoris en un tap. Tout reste à portée de main, sans fouiller.</p>
        <div class="feat-visual" style="background: linear-gradient(180deg, var(--cream-2), var(--cream-3));">
          <div style="position: absolute; inset: 22px; display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">MES PLAYLISTS</div>
              <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3);">+ Nouvelle</div>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px;">
              <span style="width: 32px; height: 32px; border-radius: 7px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: 700;">12</span>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 12.5px; font-weight: 600;">Business &amp; stratégie</div>
                <div style="font-size: 10.5px; color: var(--ink-3);">12 épisodes · 14h 30min</div>
              </div>
              <span style="color: var(--accent); font-size: 14px;">★</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px;">
              <span style="width: 32px; height: 32px; border-radius: 7px; background: linear-gradient(135deg, #B5915B, #8C6A38); display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: 700;">6</span>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 12.5px; font-weight: 600;">Pour le trajet</div>
                <div style="font-size: 10.5px; color: var(--ink-3);">6 épisodes · 4h 12min</div>
              </div>
              <span style="color: var(--ink-3); font-size: 14px;">☆</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="feat-card">
        <span class="feat-num">03</span>
        <div class="feat-ico">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M16 16l5 5"/></svg>
        </div>
        <h3>Une recherche qui retrouve tout, dans tout.</h3>
        <p>Tapez un mot, une idée, un nom. Audioask vous emmène pile sur le bon passage, dans tous les épisodes que vous avez transcrits ou marqués.</p>
        <div class="feat-visual">
          <div style="position: absolute; inset: 24px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 8px; font-size: 13px;">
              <span style="color: var(--ink-3);">⌕</span>
              <span style="color: var(--ink);">tokenomics</span>
              <span style="margin-left: auto; font-family: var(--mono); font-size: 10px; color: var(--ink-3);">⌘K</span>
            </div>
            <div style="margin-top: 12px; display: flex; flex-direction: column; gap: 6px;">
              <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 8px 12px; display: flex; gap: 10px; font-size: 11.5px;">
                <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10px;">42:11</span>
                <span style="color: var(--ink-2);">« …repenser la <span style="background: var(--accent-soft); padding: 0 3px;">tokenomics</span> du protocole… »</span>
              </div>
              <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 8px 12px; display: flex; gap: 10px; font-size: 11.5px;">
                <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10px;">1:12:08</span>
                <span style="color: var(--ink-2);">« …la <span style="background: var(--accent-soft); padding: 0 3px;">tokenomics</span> récompense la rareté… »</span>
              </div>
              <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 8px 12px; display: flex; gap: 10px; font-size: 11.5px;">
                <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10px;">2:03:47</span>
                <span style="color: var(--ink-2);">« On revient à la <span style="background: var(--accent-soft); padding: 0 3px;">tokenomics</span> que personne… »</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 4 -->
      <div class="feat-card">
        <span class="feat-num">04</span>
        <div class="feat-ico">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg>
        </div>
        <h3>Les nouveaux épisodes traités automatiquement. Pendant que vous dormez.</h3>
        <p>Activez l'automatisation d'un channel : chaque nouvel épisode est transcrit, analysé et livré là où vous le souhaitez. Bibliothèque, email, Slack — au choix.</p>
        <div class="feat-visual">
          <div style="position: absolute; inset: 22px; display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">JOURNAL AUTO · ACQUIRED</span>
              <span class="chip accent-soft" style="font-size: 10px; height: 20px; padding: 0 8px;">⚡ ACTIF</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; display: flex; gap: 10px; align-items: center; font-size: 11.5px;">
              <span style="color: var(--accent);">●</span>
              <div style="flex: 1; min-width: 0;"><div style="font-weight: 600;">#119 — Nvidia</div><div style="color: var(--ink-3); font-size: 10.5px;">Il y a 12 min · Email envoyé</div></div>
              <span style="font-family: var(--mono); font-size: 9px; color: var(--accent);">✓</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; display: flex; gap: 10px; align-items: center; font-size: 11.5px;">
              <span style="color: var(--accent);">●</span>
              <div style="flex: 1; min-width: 0;"><div style="font-weight: 600;">#118 — Costco</div><div style="color: var(--ink-3); font-size: 10.5px;">Hier · Bibliothèque</div></div>
              <span style="font-family: var(--mono); font-size: 9px; color: var(--accent);">✓</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; display: flex; gap: 10px; align-items: center; font-size: 11.5px;">
              <span style="color: var(--accent);">●</span>
              <div style="flex: 1; min-width: 0;"><div style="font-weight: 600;">#117 — Hermès</div><div style="color: var(--ink-3); font-size: 10.5px;">10 mai · Bibliothèque + email</div></div>
              <span style="font-family: var(--mono); font-size: 9px; color: var(--accent);">✓</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DÉCOUVRIR LES FONCTIONNALITÉS -->
<section class="section alt">
  <div class="container">
    <div class="row between" style="align-items: flex-end; gap: 32px; flex-wrap: wrap;">
      <div>
        <div class="eyebrow"><span class="dot">●</span> Explorer en détail</div>
        <h2 style="margin-top: 16px;">Les fonctionnalités clés<br>en un coup d'œil.</h2>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 48px;">
      <a href="/fonctionnalites/transcrire" class="discover-card">
        <div class="feat-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/></svg></div>
        <h4>Transcrire</h4>
        <p>De l'audio au texte structuré en quelques minutes.</p>
        <span class="discover-link">En savoir plus <span class="arrow">→</span></span>

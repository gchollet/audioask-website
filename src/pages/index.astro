<script>
(function () {
  /* --- Animation product-stage au scroll --- */
  var stage = document.getElementById('product-stage');
  if (!stage) return;
  if (!('IntersectionObserver' in window)) {
    stage.classList.add('in-view');
  } else {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { stage.classList.add('in-view'); io.disconnect(); }
      });
    }, { threshold: 0.25 });
    io.observe(stage);
  }
})();
</script>


<script>
(function () {
  const stage = document.getElementById('product-stage');
  if (!stage) return;
  if (!('IntersectionObserver' in window)) { stage.classList.add('in-view'); return; }
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { stage.classList.add('in-view'); io.disconnect(); }
    });
  }, { threshold: 0.35 });
  io.observe(stage);
})();
</script>

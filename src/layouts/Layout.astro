---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  ogImage?: string;
  lang?: 'fr' | 'en';
  alternatePath?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'AudioAsk — Transcription, IA et automatisation pour vos podcasts. Signets, recherche plein-texte, analyses IA avec citations vérifiables.',
  activePage = '',
  ogImage = '/og-default.png',
  lang = 'fr',
  alternatePath,
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
// Normalise le slash final pour que les URLs hreflang correspondent exactement
// aux canonical/sitemap générés par Astro (évite les incohérences pour Google/Bing).
const withTrailingSlash = (path: string) => {
  const u = new URL(path, Astro.site);
  if (!u.pathname.endsWith('/') && !u.pathname.split('/').pop()?.includes('.')) {
    u.pathname += '/';
  }
  return u.href;
};
const alternateUrl = alternatePath ? withTrailingSlash(alternatePath) : null;
const homeUrl = new URL('/', Astro.site).href;

// JSON-LD global : Organisation + site web (aide Google/Bing à comprendre la marque).
// Les @id permettent aux pages de référencer ces entités sans les redéclarer.
const orgId = `${homeUrl}#organization`;
const websiteId = `${homeUrl}#website`;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': orgId,
  name: 'Audioask',
  legalName: 'Natives Sàrl',
  url: homeUrl,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/favicon.svg', Astro.site).href,
  },
  description: 'Transcription, traduction, IA et automatisation pour vos podcasts.',
  foundingLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Carouge',
      addressRegion: 'Genève',
      addressCountry: 'CH',
    },
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': websiteId,
  name: 'Audioask',
  url: homeUrl,
  inLanguage: lang === 'en' ? 'en' : 'fr',
  publisher: { '@id': orgId },
};
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- SEO de base -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
  <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <meta name="bingbot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <meta name="theme-color" content="#E97146" />
  <meta name="generator" content="Astro" />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- hreflang (bidirectionnel + auto-référencé, recommandé par Google) -->
  {alternateUrl && <link rel="alternate" hreflang={lang} href={canonicalUrl} />}
  {alternateUrl && <link rel="alternate" hreflang={lang === 'fr' ? 'en' : 'fr'} href={alternateUrl} />}
  {alternateUrl && <link rel="alternate" hreflang="x-default" href={lang === 'fr' ? canonicalUrl : alternateUrl} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Audioask" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Audioask" />
  <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'fr_FR'} />
  <meta property="og:locale:alternate" content={lang === 'en' ? 'fr_FR' : 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content="Audioask" />

  <!-- JSON-LD global : Organisation + site web -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Vérification moteurs de recherche -->
  <meta name="google-site-verification" content="i0oux5x3g014q4OffXVgq9x9KcyaPD_a7Q6DqQJSa1s" />
  <meta name="msvalidate.01" content="E785E91D631CDE5CEAFA56CE87158AD3" />

  <!-- Slot pour JSON-LD et meta supplémentaires par page -->
  <slot name="head" />
</head>
<body>
  <Header activePage={activePage} lang={lang} alternatePath={alternatePath} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
